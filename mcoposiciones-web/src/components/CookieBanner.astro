<div id="cookie-banner" class="fixed bottom-4 inset-x-4 z-[60] hidden md:left-auto md:right-6 md:bottom-6 md:max-w-md rounded-2xl border border-primary/10 bg-white p-6 text-text-main shadow-premium transition-all duration-300" role="region" aria-label="Aviso de cookies">
	<div class="flex flex-col gap-4">
		<div class="flex items-center gap-2.5">
			<span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-secondary/10 text-secondary">
				<svg class="h-4.5 w-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5Z"/></svg>
			</span>
			<p class="font-extrabold text-primary tracking-tight text-base">Uso de cookies</p>
		</div>
		<p class="text-sm leading-relaxed text-text-muted">
			Usamos cookies propias y de terceros (Google Analytics) para analizar el uso del sitio. Puedes aceptarlas o rechazarlas.
			<a href="/politica-cookies/" class="font-bold text-secondary no-underline hover:text-accent">Ver política</a>.
		</p>
		<div class="flex gap-3 mt-1">
			<button id="cookie-accept" type="button" class="flex-1 rounded-xl bg-secondary py-3 text-sm font-bold text-white shadow-button transition hover:-translate-y-0.5 hover:bg-primary cursor-pointer">
				Aceptar todas
			</button>
			<button id="cookie-reject" type="button" class="flex-1 rounded-xl border border-primary/10 py-3 text-sm font-bold text-text-muted hover:text-primary transition hover:-translate-y-0.5 hover:bg-bg-light/40 cursor-pointer">
				Solo necesarias
			</button>
		</div>
	</div>
</div>

<script is:inline>
	(() => {
		const banner = document.getElementById('cookie-banner');
		const acceptButton = document.getElementById('cookie-accept');
		const rejectButton = document.getElementById('cookie-reject');
		const getConsent = () => {
			try {
				return localStorage.getItem('cookie_consent');
			} catch {
				return null;
			}
		};
		const setConsent = (value) => {
			try {
				localStorage.setItem('cookie_consent', value);
			} catch {
				// Si localStorage no está disponible, se respeta la elección solo durante la sesión actual.
			}
		};
		const hideBanner = () => banner?.classList.add('hidden');
		const showBanner = () => banner?.classList.remove('hidden');

		const consent = getConsent();
		if (consent === 'accepted') {
			hideBanner();
			window.loadGoogleAnalytics?.();
		} else if (consent === 'rejected') {
			hideBanner();
		} else {
			showBanner();
		}

		acceptButton?.addEventListener('click', () => {
			setConsent('accepted');
			hideBanner();
			window.loadGoogleAnalytics?.();
		});

		rejectButton?.addEventListener('click', () => {
			setConsent('rejected');
			hideBanner();
		});
	})();
</script>
