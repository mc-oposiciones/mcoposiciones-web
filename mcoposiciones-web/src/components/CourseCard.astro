---
interface Props {
	title: string;
	description: string;
	price: string;
	priceType: string;
	badge?: string;
	href: string;
	features: string[];
}
const { title, description, price, priceType, badge, href, features } = Astro.props;
---

<article class="group relative flex h-full flex-col overflow-hidden rounded-2xl border border-primary/5 bg-white p-7 shadow-premium transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-1.5 hover:scale-[1.01] hover:border-secondary/20 hover:shadow-premium-hover">
	{badge && (
		<span class="absolute right-4 top-4 rounded-full bg-accent/15 px-3 py-1 text-[9px] font-bold uppercase tracking-widest text-primary border border-accent/25">
			{badge}
		</span>
	)}
	<div class="mb-6">
		<h3 class="text-2xl font-extrabold text-primary transition-colors duration-300 group-hover:text-secondary">{title}</h3>
		<p class="mt-3 text-sm leading-relaxed text-text-muted/90">{description}</p>
	</div>
	<ul class="mb-8 space-y-4">
		{features.map((feature) => (
			<li class="flex items-start gap-3">
				<span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-secondary/10 text-secondary">
					<svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" /></svg>
				</span>
				<span class="text-sm font-medium text-text-main/90">{feature}</span>
			</li>
		))}
	</ul>
	<div class="mt-auto pt-6 border-t border-primary/5">
		<div class="flex items-baseline gap-1">
			<span class="text-4xl font-black text-primary tracking-tight">{price}</span>
			<span class="text-sm font-bold text-text-muted/85">{priceType}</span>
		</div>
		<a href={href} class="mt-6 flex w-full items-center justify-center rounded-xl bg-secondary px-6 py-4 text-sm font-bold text-white no-underline shadow-button hover:bg-accent hover:text-primary transition-all duration-300 active:scale-[0.98]">
			Ver detalles del curso
		</a>
	</div>
</article>
