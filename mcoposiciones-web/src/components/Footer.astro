---
const socialLinks = [
	{
		label: 'TikTok',
		href: 'https://www.tiktok.com/@mcoposiciones',
		paths: ['M14 3c.4 2.7 1.9 4.4 4.5 4.7v3.1a8 8 0 0 1-4.4-1.3v5.8a5.7 5.7 0 1 1-5.7-5.7h.8v3.2a2.5 2.5 0 1 0 1.7 2.4V3h3.1Z'],
	},
	{
		label: 'Instagram',
		href: 'https://www.instagram.com/mcoposiciones',
		paths: ['M8 4h8a4 4 0 0 1 4 4v8a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4V8a4 4 0 0 1 4-4Z', 'M12 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6Z', 'M17 7.2h.01'],
	},
	{
		label: 'YouTube',
		href: 'https://www.youtube.com/@mcoposiciones',
		paths: ['M21 12s0-3.2-.4-4.5c-.2-.8-.9-1.4-1.7-1.6C17.4 5.5 12 5.5 12 5.5s-5.4 0-6.9.4c-.8.2-1.5.8-1.7 1.6C3 8.8 3 12 3 12s0 3.2.4 4.5c.2.8.9 1.4 1.7 1.6 1.5.4 6.9.4 6.9.4s5.4 0 6.9-.4c.8-.2 1.5-.8 1.7-1.6.4-1.3.4-4.5.4-4.5Z', 'm10.3 14.7 4.5-2.7-4.5-2.7v5.4Z'],
	},
];

const formationLinks = [
	{ href: '/oposiciones-administrativo-estado/', label: 'AGE C1' },
	{ href: '/oposiciones-seguridad-social/', label: 'Seguridad Social C1' },
	{ href: '/preparar-age-y-seguridad-social/', label: 'Pack AGE + SS' },
	{ href: '/cursos-precios/', label: 'Cursos y precios' },
];

const resourceLinks = [
	{ href: '/preparadora-oposiciones/', label: 'Sobre Mª Carmen', reload: true },
	{ href: '/preparadora-age/', label: 'Preparadora AGE' },
	{ href: '/preparadora-seguridad-social/', label: 'Preparadora SS' },
	{ href: '/blog/', label: 'Blog' },
	{ href: '/contacto/', label: 'Contacto' },
];
---

<footer class="border-t border-[#6b5f5f] bg-[#665a5a] text-white">
	<div class="mx-auto max-w-7xl px-6 pb-6 pt-10 lg:px-8">
		<div class="grid grid-cols-2 gap-6 lg:grid-cols-[1.2fr_0.8fr_0.8fr_1fr] lg:items-start">
			<div class="col-span-2 lg:col-span-1">
				<a href="/" class="text-2xl font-extrabold tracking-tight text-white no-underline hover:text-white" data-astro-reload>
					MC Oposiciones
				</a>
				<p class="mt-4 max-w-sm text-sm leading-relaxed text-white/72">
					Preparación online para Administrativo del Estado y Seguridad Social con clases en directo, grupos reducidos y seguimiento cercano.
				</p>
				<div class="mt-4 inline-flex items-center gap-2 rounded-full border border-white/16 bg-white/7 px-4 py-1.5">
					<span class="h-2 w-2 rounded-full bg-secondary"></span>
					<span class="text-xs font-bold uppercase tracking-widest text-white/85">Grupos 2026 abiertos</span>
				</div>
			</div>

			<nav aria-label="Formación">
				<h2 class="text-xs font-extrabold uppercase tracking-widest text-accent-light">Formación</h2>
				<ul class="mt-3 space-y-1.5 text-sm">
					{formationLinks.map((link) => (
						<li>
							<a href={link.href} data-astro-reload={link.reload} class="text-white/76 no-underline transition-colors hover:text-white">
								{link.label}
							</a>
						</li>
					))}
				</ul>
			</nav>

			<nav aria-label="Recursos">
				<h2 class="text-xs font-extrabold uppercase tracking-widest text-accent-light">Recursos</h2>
				<ul class="mt-3 space-y-1.5 text-sm">
					{resourceLinks.map((link) => (
						<li>
							<a href={link.href} data-astro-reload={link.reload} class="text-white/76 no-underline transition-colors hover:text-white">
								{link.label}
							</a>
						</li>
					))}
				</ul>
			</nav>

			<div class="col-span-2 md:col-span-1 lg:col-span-1">
				<h2 class="text-xs font-extrabold uppercase tracking-widest text-accent-light">Contacto directo</h2>
				<div class="mt-3 space-y-2 text-sm">
					<a href="mailto:infomcoposiciones@gmail.com" class="group flex items-center gap-2.5 text-white/76 no-underline transition-colors hover:text-white">
						<span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-white/12 bg-white/8 text-accent-light transition-colors group-hover:border-secondary group-hover:bg-secondary group-hover:text-white">
							<svg class="h-4.5 w-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 7 9 6 9-6" /><path d="M4 5h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Z" /></svg>
						</span>
						<span>infomcoposiciones@gmail.com</span>
					</a>
					<a href="https://wa.me/34642170664" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-2.5 text-white/76 no-underline transition-colors hover:text-white">
						<span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-white/12 bg-white/8 text-accent-light transition-colors group-hover:border-secondary group-hover:bg-secondary group-hover:text-white">
							<svg class="h-5.5 w-5.5" viewBox="0 0 32 32" fill="none" aria-hidden="true"><path fill="currentColor" d="M16.02 3C8.86 3 3.03 8.82 3.03 15.98c0 2.28.6 4.52 1.73 6.49L3 29l6.68-1.76a12.88 12.88 0 0 0 6.34 1.64C23.18 28.88 29 23.06 29 15.9 29 8.76 23.18 3 16.02 3Zm0 23.7c-1.95 0-3.86-.52-5.54-1.5l-.39-.23-3.98 1.04 1.06-3.87-.26-.4a10.7 10.7 0 1 1 9.11 4.96Z" /><path fill="currentColor" d="M21.92 18.84c-.32-.16-1.9-.94-2.2-1.05-.3-.11-.52-.16-.74.16-.22.32-.85 1.05-1.04 1.27-.19.22-.38.24-.7.08-.32-.16-1.36-.5-2.6-1.6-.96-.86-1.6-1.92-1.8-2.24-.19-.32-.02-.5.14-.66.14-.14.32-.38.48-.56.16-.19.22-.32.32-.53.11-.22.05-.4-.03-.56-.08-.16-.74-1.78-1.02-2.44-.27-.64-.54-.55-.74-.56h-.63c-.22 0-.56.08-.85.4-.3.32-1.12 1.1-1.12 2.68s1.15 3.1 1.31 3.32c.16.22 2.26 3.46 5.48 4.85.77.33 1.37.53 1.84.68.77.25 1.47.21 2.02.13.62-.09 1.9-.78 2.17-1.53.27-.75.27-1.39.19-1.53-.08-.14-.3-.22-.62-.38Z" /></svg>
						</span>
						<span>642 170 664</span>
					</a>
				</div>
				<a href="/contacto/" class="mt-4 inline-flex rounded-xl bg-secondary px-4 py-2.5 text-sm font-bold text-white no-underline transition-colors hover:bg-white hover:text-primary">
					Consultar preparación
				</a>
			</div>
		</div>

		<div class="mt-8 flex flex-col gap-5 border-t border-white/12 pt-5 md:flex-row md:items-center md:justify-between">
			<div class="flex items-center gap-3">
				{socialLinks.map((social) => (
					<a href={social.href} target="_blank" rel="noopener noreferrer" class="flex h-9 w-9 items-center justify-center rounded-xl border border-white/12 bg-white/6 text-white/80 no-underline transition-colors hover:border-secondary hover:bg-secondary hover:text-white" aria-label={social.label}>
						<svg class="h-4.5 w-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
							{social.paths.map((path) => <path d={path} />)}
						</svg>
					</a>
				))}
			</div>

			<div class="flex flex-col gap-4 text-xs font-semibold text-white/62 md:flex-row md:items-center">
				<span>© 2026 MC Oposiciones</span>
				<div class="flex flex-wrap gap-4">
					<a href="/politica-privacidad/" class="text-white/62 no-underline transition-colors hover:text-white">Privacidad</a>
					<a href="/aviso-legal/" class="text-white/62 no-underline transition-colors hover:text-white">Legal</a>
					<a href="/politica-cookies/" class="text-white/62 no-underline transition-colors hover:text-white">Cookies</a>
				</div>
			</div>
		</div>
	</div>
</footer>
