---
const socialLinks = [
	{
		label: 'TikTok',
		href: 'https://www.tiktok.com/@mcoposiciones',
		paths: ['M14 3c.4 2.7 1.9 4.4 4.5 4.7v3.1a8 8 0 0 1-4.4-1.3v5.8a5.7 5.7 0 1 1-5.7-5.7h.8v3.2a2.5 2.5 0 1 0 1.7 2.4V3h3.1Z'],
		color: 'bg-secondary/10 text-secondary hover:bg-secondary hover:text-white',
	},
	{
		label: 'Instagram',
		href: 'https://www.instagram.com/mcoposiciones',
		paths: ['M8 4h8a4 4 0 0 1 4 4v8a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4V8a4 4 0 0 1 4-4Z', 'M12 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6Z', 'M17 7.2h.01'],
		color: 'bg-secondary/10 text-secondary hover:bg-secondary hover:text-white',
	},
	{
		label: 'YouTube',
		href: 'https://www.youtube.com/@mcoposiciones',
		paths: ['M21 12s0-3.2-.4-4.5c-.2-.8-.9-1.4-1.7-1.6C17.4 5.5 12 5.5 12 5.5s-5.4 0-6.9.4c-.8.2-1.5.8-1.7 1.6C3 8.8 3 12 3 12s0 3.2.4 4.5c.2.8.9 1.4 1.7 1.6 1.5.4 6.9.4 6.9.4s5.4 0 6.9-.4c.8-.2 1.5-.8 1.7-1.6.4-1.3.4-4.5.4-4.5Z', 'm10.3 14.7 4.5-2.7-4.5-2.7v5.4Z'],
		color: 'bg-secondary/10 text-secondary hover:bg-secondary hover:text-white',
	},
];
---

<footer class="mt-20 border-t border-primary/5 bg-white">
	<div class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
		<div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:items-start lg:gap-12">
			<!-- Columna Marca -->
			<div class="lg:col-span-4 flex flex-col h-full">
				<a href="/" class="inline-block no-underline transition-transform hover:scale-[1.02]">
					<img src="/logo.png" alt="MC Oposiciones" class="h-9 w-auto" />
				</a>
				<p class="mt-6 text-sm leading-relaxed text-text-muted max-w-sm">
					Preparadora especializada en Administrativo del Estado y Seguridad Social. Método directo enfocado a resultados reales.
				</p>
			</div>

			<!-- Navegación Cursos -->
			<div class="lg:col-span-2 flex flex-col gap-6">
				<h3 class="text-[10px] font-black uppercase tracking-[0.25em] text-accent">Formación</h3>
				<ul class="flex flex-col gap-3 text-sm font-bold text-primary">
					<li><a href="/oposiciones-administrativo-estado/" class="no-underline transition-all hover:text-secondary hover:translate-x-1 inline-block">AGE C1</a></li>
					<li><a href="/oposiciones-seguridad-social/" class="no-underline transition-all hover:text-secondary hover:translate-x-1 inline-block">Seg. Social</a></li>
					<li><a href="/preparadora-age/" class="no-underline transition-all hover:text-secondary hover:translate-x-1 inline-block">Preparadora AGE</a></li>
					<li><a href="/preparadora-seguridad-social/" class="no-underline transition-all hover:text-secondary hover:translate-x-1 inline-block">Preparadora SS</a></li>
					<li><a href="/preparar-age-y-seguridad-social/" class="no-underline transition-all hover:text-secondary hover:translate-x-1 inline-block">Pack Doble</a></li>
					<li><a href="/cursos-precios/" class="no-underline transition-all hover:text-secondary hover:translate-x-1 inline-block">Planes</a></li>
				</ul>
			</div>

			<!-- Navegación Info -->
			<div class="lg:col-span-2 flex flex-col gap-6">
				<h3 class="text-[10px] font-black uppercase tracking-[0.25em] text-accent">Recursos</h3>
				<ul class="flex flex-col gap-3 text-sm font-bold text-primary">
					<li><a href="/preparadora-oposiciones/" class="no-underline transition-all hover:text-secondary hover:translate-x-1 inline-block">Sobre Mª Carmen</a></li>
					<li><a href="/blog/" class="no-underline transition-all hover:text-secondary hover:translate-x-1 inline-block">Blog</a></li>
					<li><a href="/clases-muestra/" class="no-underline transition-all hover:text-secondary hover:translate-x-1 inline-block">Muestras</a></li>
					<li><a href="/contacto/" class="no-underline transition-all hover:text-secondary hover:translate-x-1 inline-block">Contacto</a></li>
				</ul>
			</div>

			<!-- Contacto -->
			<div class="lg:col-span-4 flex flex-col gap-6">
				<h3 class="text-[10px] font-black uppercase tracking-[0.25em] text-accent">Atención Directa</h3>
				<div class="flex flex-col gap-3">
					<a href="mailto:infomcoposiciones@gmail.com" class="group flex items-center gap-3 no-underline">
						<div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-secondary/5 text-secondary group-hover:bg-secondary group-hover:text-white transition-colors border border-secondary/5">
							<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 7 9 6 9-6M4 5h16c1.1 0 2 .9 2 2v10c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V7c0-1.1.9-2 2-2z"/></svg>
						</div>
						<span class="text-xs font-bold text-primary">infomcoposiciones@gmail.com</span>
					</a>
					<a href="tel:+34642170664" class="group flex items-center gap-3 no-underline">
						<div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-secondary/5 text-secondary group-hover:bg-secondary group-hover:text-white transition-colors border border-secondary/5">
							<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
						</div>
						<span class="text-xs font-bold text-primary">642 170 664</span>
					</a>
					<div class="mt-1 inline-flex items-center gap-2 rounded-xl bg-secondary/5 px-3 py-1.5 border border-secondary/10 w-fit">
						<span class="h-1.5 w-1.5 rounded-full bg-secondary animate-pulse"></span>
						<span class="text-[9px] font-black uppercase tracking-widest text-secondary">Plazas Abiertas 2026</span>
					</div>
				</div>
			</div>
		</div>

		<!-- Barra Inferior: Ultra-Minimalista & Alineación de Precisión -->
		<div class="mt-16 pt-8 border-t border-primary/5 flex flex-col gap-8 md:flex-row md:items-center md:justify-between">
			<!-- Redes Sociales: Diseño "Cápsula Premium" Multicolor -->
			<div class="flex items-center gap-3.5">
				{socialLinks.map((social) => (
					<a href={social.href} target="_blank" rel="noopener noreferrer" class:list={['flex h-11 w-11 items-center justify-center rounded-2xl shadow-sm border border-black/5 transition-all hover:-translate-y-1.5 hover:shadow-md active:scale-95', social.color]} aria-label={social.label}>
						<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
							{social.paths.map((path) => <path d={path} />)}
						</svg>
					</a>
				))}
			</div>

			<!-- Copyright y Legal: Misma Línea Base Milimétrica -->
			<div class="flex items-center gap-4 text-[10px] font-bold uppercase tracking-[0.2em] text-text-muted/80">
				<span>© 2026 MC Oposiciones</span>
				<span class="w-1 h-1 rounded-full bg-primary/10"></span>
				<div class="flex items-center gap-4">
					<a href="/politica-privacidad/" class="no-underline hover:text-primary transition-colors">Privacidad</a>
					<a href="/aviso-legal/" class="no-underline hover:text-primary transition-colors">Legal</a>
					<a href="/politica-cookies/" class="no-underline hover:text-primary transition-colors">Cookies</a>
				</div>
			</div>
		</div>
	</div>
</footer>
