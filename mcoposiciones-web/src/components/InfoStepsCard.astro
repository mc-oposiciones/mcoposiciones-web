---
interface StepItem {
	title: string;
	text: string;
}

interface Props {
	title: string;
	eyebrow?: string;
	items: StepItem[];
	accent?: 'green' | 'orange';
}

const { title, eyebrow, items, accent = 'green' } = Astro.props;
const isOrange = accent === 'orange';
const badgeClasses = isOrange
	? 'border-accent/35 bg-accent/15 text-primary'
	: 'border-secondary/25 bg-secondary/10 text-secondary-dark';
const markerClasses = isOrange
	? 'bg-accent text-primary shadow-[0_10px_22px_-14px_rgba(254,172,124,0.9)]'
	: 'bg-secondary text-white shadow-[0_10px_22px_-14px_rgba(42,157,143,0.9)]';
const topBarClass = isOrange ? 'bg-accent' : 'bg-secondary';
---

<aside class="relative overflow-hidden rounded-2xl border border-primary/10 bg-white p-5 shadow-premium md:p-6">
	<div class={`pointer-events-none absolute inset-x-0 top-0 h-1 ${topBarClass}`}></div>
	{eyebrow && (
		<p class={`inline-flex rounded-full border px-3 py-1 text-[10px] font-extrabold uppercase tracking-widest ${badgeClasses}`}>
			{eyebrow}
		</p>
	)}
	<h3 class="mt-4 text-xl font-extrabold tracking-tight text-primary md:text-2xl">{title}</h3>
	<div class="mt-5 grid gap-2.5">
		{items.map((item, index) => (
			<div class="group grid grid-cols-[2.35rem_1fr] gap-3.5 rounded-xl border border-primary/5 bg-bg-light/45 p-3.5 transition-all duration-300 hover:border-secondary/20 hover:bg-white hover:shadow-premium">
				<span class={`flex h-9 w-9 items-center justify-center rounded-lg text-xs font-black ${markerClasses}`}>
					{String(index + 1).padStart(2, '0')}
				</span>
				<div>
					<h4 class="text-sm font-extrabold leading-snug text-primary group-hover:text-secondary md:text-base">{item.title}</h4>
					<p class="mt-1 text-sm leading-relaxed text-text-muted">{item.text}</p>
				</div>
			</div>
		))}
	</div>
</aside>
