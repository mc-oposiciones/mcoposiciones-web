---
const currentPath = Astro.url.pathname;
const normalizePath = (path: string) => (path === '/' ? '/' : path.replace(/\/$/, ''));
const isActive = (href: string) => {
	if (href.includes('#')) return false;
	const normalizedCurrent = normalizePath(currentPath);
	const normalizedHref = normalizePath(href);
	return normalizedHref === '/'
		? normalizedCurrent === '/'
		: normalizedCurrent === normalizedHref || normalizedCurrent.startsWith(`${normalizedHref}/`);
};

const oppositionLinks = [
	{ label: 'AGE C1', description: 'Administrativo del Estado', href: '/oposiciones-administrativo-estado/' },
	{ label: 'Seguridad Social C1', description: 'Administrativo SS', href: '/oposiciones-seguridad-social/' },
	{ label: 'Pack AGE + SS', description: 'Preparación conjunta', href: '/preparar-age-y-seguridad-social/', badge: 'Doble vía', featured: true },
];

const navLinks = [
	{ label: 'Precios', href: '/cursos-precios/' },
	{ label: 'Clases gratis', href: '/clases-muestra/' },
	{ label: 'Opiniones', href: '/#opiniones' },
	{ label: 'Blog', href: '/blog/' },
	{ label: 'Sobre mí', href: '/preparadora-oposiciones/' },
];

const oppositionsActive = oppositionLinks.some((item) => isActive(item.href));
---

<header id="site-header" class="fixed inset-x-0 top-0 z-50 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]">
	<div class="mx-auto max-w-7xl px-4 py-3 sm:px-6 lg:px-8">
		<nav class="flex items-center justify-between rounded-xl border border-primary/5 bg-white/80 px-4 py-2 shadow-premium backdrop-blur-md lg:px-5" aria-label="Navegacion principal">
			<a href="/" class="flex items-center no-underline transition-all duration-300 hover:opacity-90 hover:scale-[1.01]" aria-label="MC Oposiciones">
				<img src="/logo.png" alt="MC Oposiciones" width="300" height="80" loading="eager" fetchpriority="high" class="h-9 w-auto md:h-10" />
			</a>

			<div id="site-menu" class="hidden items-center gap-1.5 lg:flex">
				<a href="/" class:list={['relative rounded-lg px-3 py-2 text-sm font-semibold no-underline transition-all duration-300 hover:bg-bg-light/60', isActive('/') ? 'text-secondary' : 'text-primary']}>
					Inicio
					{isActive('/') && <span class="absolute bottom-1 left-3 right-3 h-0.5 rounded-full bg-accent animate-in fade-in zoom-in duration-500"></span>}
				</a>

				<div class="group relative">
					<button id="oppositions-menu-button" type="button" class:list={['flex items-center gap-1.5 rounded-lg px-3 py-2 text-sm font-semibold transition-all duration-300 hover:bg-bg-light/60', oppositionsActive ? 'text-secondary' : 'text-primary']} aria-expanded="false" aria-controls="oppositions-menu">
						Oposiciones
						<svg class="h-4 w-4 transition-transform duration-300 group-hover:rotate-180" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.168l3.71-3.938a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06Z" clip-rule="evenodd" /></svg>
					</button>
					<div id="oppositions-menu" class="invisible absolute left-0 top-full w-82 origin-top-left -translate-y-1 scale-95 rounded-xl border border-primary/5 bg-white p-2 opacity-0 shadow-premium transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:visible group-hover:translate-y-1 group-hover:scale-100 group-hover:opacity-100">
						{oppositionLinks.map((item) => (
							<a href={item.href} class:list={['flex items-center justify-between gap-3 rounded-lg px-4 py-3 text-sm no-underline transition-colors duration-200', item.featured ? 'bg-accent-light/20 font-bold text-primary hover:bg-accent-light/40' : 'text-primary hover:bg-bg-light/60', isActive(item.href) && 'text-secondary bg-bg-light/80']}>
								<span>
									<span class="block font-bold tracking-tight">{item.label}</span>
									<span class="block text-xs font-medium text-text-muted/80">{item.description}</span>
								</span>
								{item.badge && <span class="rounded-full bg-accent/20 px-2 py-0.5 text-[9px] font-bold uppercase tracking-wider text-primary border border-accent/30">{item.badge}</span>}
							</a>
						))}
					</div>
				</div>

				{navLinks.map((item) => (
					<a href={item.href} class:list={['relative rounded-lg px-3 py-2 text-sm font-semibold no-underline transition-all duration-300 hover:bg-bg-light/60', isActive(item.href) ? 'text-secondary' : 'text-primary']}>
						{item.label}
						{isActive(item.href) && <span class="absolute bottom-1 left-3 right-3 h-0.5 rounded-full bg-accent animate-in fade-in zoom-in duration-500"></span>}
					</a>
				))}

				<a href="/contacto/" class:list={['ml-2 rounded-lg px-5 py-2.5 text-sm font-bold no-underline transition-all duration-300 shadow-button hover:shadow-premium-hover hover:scale-[1.02] active:scale-[0.98]', isActive('/contacto/') ? 'bg-accent text-primary' : 'bg-secondary text-white hover:bg-accent hover:text-primary']}>
					Contacto
				</a>
			</div>

			<button id="mobile-menu-button" type="button" class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-primary/5 text-primary lg:hidden transition-colors duration-200 hover:bg-bg-light/60" aria-label="Abrir menu" aria-controls="mobile-menu" aria-expanded="false">
				<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16" /></svg>
			</button>
		</nav>
	</div>

	<div id="mobile-menu" class="fixed inset-0 z-[-1] hidden bg-bg-light/98 backdrop-blur-xl animate-in fade-in slide-in-from-top-4 duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] lg:hidden">
		<div class="flex h-full flex-col p-6 pt-24">
			<div class="flex flex-col gap-2">
				<a href="/" class:list={['rounded-xl px-4 py-3 text-lg font-bold no-underline transition-all', isActive('/') ? 'bg-secondary text-white shadow-button' : 'text-primary hover:bg-white']}>Inicio</a>
				<div class="flex flex-col gap-1">
					<p class="px-4 py-2 text-xs font-bold uppercase tracking-wider text-text-muted/60">Oposiciones</p>
					{oppositionLinks.map((item) => (
						<a href={item.href} class:list={['flex items-center justify-between rounded-xl px-4 py-3 text-base font-semibold no-underline transition-all', isActive(item.href) ? 'bg-secondary/10 text-secondary' : 'text-primary hover:bg-white']}>
							<span>
								<span class="block font-bold">{item.label}</span>
								<span class="block text-xs font-medium text-text-muted/80">{item.description}</span>
							</span>
							{item.badge && <span class="rounded-full bg-accent/20 px-2 py-0.5 text-[9px] font-bold text-primary border border-accent/20">{item.badge}</span>}
						</a>
					))}
				</div>
				{navLinks.map((item) => (
					<a href={item.href} class:list={['rounded-xl px-4 py-3 text-lg font-bold no-underline transition-all', isActive(item.href) ? 'bg-secondary text-white shadow-button' : 'text-primary hover:bg-white']}>{item.label}</a>
				))}
			</div>
			<div class="mt-auto pb-10">
				<a href="/contacto/" class="flex w-full items-center justify-center rounded-xl bg-secondary py-4 text-lg font-bold text-white no-underline shadow-button hover:bg-accent hover:text-primary transition-all duration-300">
					Contactar con Mª Carmen
				</a>
			</div>
		</div>
	</div>
</header>

<script>
	const header = document.getElementById('site-header');
	const mobileButton = document.getElementById('mobile-menu-button');
	const mobileMenu = document.getElementById('mobile-menu');

	const setScrolledState = () => {
		const isScrolled = window.scrollY > 20;
		header?.classList.toggle('py-2', isScrolled);
		header?.querySelector('nav')?.classList.toggle('shadow-premium-hover', isScrolled);
	};

	window.addEventListener('scroll', setScrolledState, { passive: true });

	mobileButton?.addEventListener('click', () => {
		const expanded = mobileButton.getAttribute('aria-expanded') === 'true';
		mobileButton.setAttribute('aria-expanded', String(!expanded));
		mobileMenu?.classList.toggle('hidden', expanded);
		document.body.classList.toggle('overflow-hidden', !expanded);
	});

	mobileMenu?.querySelectorAll('a').forEach((link) => {
		link.addEventListener('click', () => {
			mobileButton?.setAttribute('aria-expanded', 'false');
			mobileMenu?.classList.add('hidden');
			document.body.classList.remove('overflow-hidden');
		});
	});
</script>
