---
interface Props {
	title: string;
	kicker: string;
	text: string;
	href: string;
	cta: string;
	highlight?: boolean;
}

const { title, kicker, text, href, cta, highlight = false } = Astro.props;
---

<article class={`group relative flex h-full flex-col rounded-2xl border bg-white p-8 shadow-premium transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-2 hover:scale-[1.01] ${highlight ? 'border-accent/60 hover:shadow-[0_22px_42px_-24px_rgba(254,172,124,0.65)]' : 'border-secondary/35 hover:border-secondary/55 hover:shadow-premium-hover'}`}>
	{highlight && (
		<span class="absolute right-6 top-6 rounded-full border border-accent/30 bg-accent/15 px-3 py-1 text-[9px] font-bold uppercase tracking-widest text-primary">Recomendado</span>
	)}
	<p class={`text-xs font-bold uppercase tracking-[0.15em] ${highlight ? 'text-accent' : 'text-secondary/85'}`}>{kicker}</p>
	<h3 class={`mt-2 text-2xl font-extrabold tracking-tight transition-colors duration-300 ${highlight ? 'text-accent' : 'text-primary group-hover:text-secondary'}`}>{title}</h3>
	<p class="mt-3 grow text-sm leading-relaxed text-text-muted/90">{text}</p>
	<a href={href} class={`mt-6 inline-flex justify-center rounded-xl px-6 py-3.5 text-sm font-bold no-underline shadow-button transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] ${highlight ? 'bg-accent text-primary hover:bg-primary hover:text-white' : 'border border-secondary/30 text-secondary hover:bg-secondary hover:text-white'}`}>
		{cta}
	</a>
</article>
