---
interface Props {
	scriptCode?: string;
}
const { scriptCode = '' } = Astro.props;
---

<section class="rounded-xl border border-primary/10 bg-white p-6 shadow-md">
	<!-- TODO: Pegar aqui el codigo del widget de Trustindex obtenido en trustindex.io. -->
	{scriptCode ? <div class="trustindex-widget" set:html={scriptCode} /> : <p class="text-sm text-text-muted">Reseñas de alumnas disponibles próximamente.</p>}
</section>
