---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import CTABanner from '../components/CTABanner.astro';
const videos = [
	{ id: '-sMHGWjsHiI', title: 'Cómo hacer un supuesto práctico — Oposiciones Seguridad Social', category: 'SS', text: 'Clase centrada en el supuesto práctico, una parte decisiva del examen de Seguridad Social.' },
	{ id: '22FfcbV_1X8', title: 'El Delegado y Subdelegado del Gobierno — Temario AGE', category: 'AGE y SS', text: 'Tema común dentro de organización administrativa, útil tanto para AGE como para Seguridad Social.' },
	{ id: 'cSq1_bZa_Cs', title: 'Las Bajas en el Régimen General — Temario SS', category: 'SS', text: 'Contenido específico de Seguridad Social, esencial para entender afiliación, altas y bajas.' },
];
---
<BaseLayout
	title="Clases de Muestra Gratuitas — Oposiciones AGE y Seguridad Social | MC Oposiciones"
	description="Accede gratuitamente a clases de muestra de las oposiciones de Administrativo del Estado y Seguridad Social. Comprueba el método de Mª Carmen antes de inscribirte."
	canonicalUrl="https://mcoposiciones.com/clases-muestra/"
>
	<main class="overflow-x-hidden pt-24">
		<section class="px-4 py-16 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Clases de muestra', href: '' }]} />
				<header class="mt-12 max-w-4xl">
					<h1 class="text-4xl font-extrabold text-primary md:text-6xl">Clases de muestra gratuitas</h1>
					<p class="mt-6 text-lg leading-relaxed text-text-muted md:text-xl">
						Comprueba el método de enseñanza de Mª Carmen antes de inscribirte. Sin registros, directo al contenido.
					</p>
				</header>

				<div class="mt-16 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
					{videos.map((video) => (
						<article class="flex flex-col rounded-2xl border border-primary/5 bg-white p-6 shadow-premium transition-all duration-300 hover:-translate-y-2 hover:shadow-premium-hover">
							<div class="overflow-hidden rounded-xl">
								<YouTubeEmbed videoId={video.id} title={video.title} description={video.text} />
							</div>
							<div class="mt-6 flex-1 flex flex-col">
								<span class="text-xs font-extrabold uppercase tracking-widest text-secondary">{video.category}</span>
								<h2 class="mt-3 text-xl font-bold leading-tight text-primary">{video.title}</h2>
								<p class="mt-4 text-sm leading-relaxed text-text-muted flex-1">{video.text}</p>
							</div>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="px-4 pb-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-5xl">
				<CTABanner 
					title="¿Te gusta cómo explico?" 
					subtitle="En el curso completo tenemos cientos de horas como estas, organizadas y con material de apoyo." 
					ctaText="Quiero inscribirme" 
					ctaHref="/contacto/" 
					variant="primary"
				/>
			</div>
		</section>
	</main>
</BaseLayout>

