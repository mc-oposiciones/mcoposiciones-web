---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<BaseLayout
	title="Contacto — MC Oposiciones | Preparadora AGE y Seguridad Social"
	description="Contacta con Mª Carmen para resolver tus dudas sobre las oposiciones de AGE o Seguridad Social. Respuesta en menos de 24 horas en días laborables."
	canonicalUrl="https://mcoposiciones.com/contacto/"
>
	<main class="overflow-x-hidden pt-24">
		<section class="px-4 py-16 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Contacto', href: '' }]} />
				<header class="mb-12 mt-12 max-w-4xl">
					<p class="text-sm font-extrabold uppercase tracking-[0.2em] text-secondary/90">Estamos aquí para ayudarte</p>
					<h1 class="mt-4 text-4xl font-extrabold leading-tight tracking-tight text-primary md:text-6xl">Contacta con Mª Carmen</h1>
					<p class="mt-6 max-w-3xl text-lg leading-relaxed text-text-muted/90 md:text-xl">
						Resuelvo tus dudas sobre la preparación, los grupos y el temario en menos de 24 horas en días laborables.
					</p>
				</header>

				<div class="grid gap-8 lg:grid-cols-[1fr_380px] lg:items-stretch">
					<div class="rounded-2xl border border-primary/5 bg-white p-8 shadow-premium md:p-12">
						<form id="contact-form" class="space-y-7" novalidate>
							<div class="grid gap-6 md:grid-cols-2">
								<label class="block">
									<span class="text-xs font-bold uppercase tracking-[0.15em] text-primary/50">Nombre completo</span>
									<input name="name" type="text" required placeholder="Tu nombre" class="mt-2.5 w-full rounded-xl border border-primary/8 bg-bg-light/50 px-5 py-4 text-primary outline-none transition-all duration-300 placeholder:text-text-muted/40 focus:border-secondary/40 focus:bg-white focus:ring-4 focus:ring-secondary/5" />
								</label>
								<label class="block">
									<span class="text-xs font-bold uppercase tracking-[0.15em] text-primary/50">Email de contacto</span>
									<input name="email" type="email" required placeholder="ejemplo@correo.com" class="mt-2.5 w-full rounded-xl border border-primary/8 bg-bg-light/50 px-5 py-4 text-primary outline-none transition-all duration-300 placeholder:text-text-muted/40 focus:border-secondary/40 focus:bg-white focus:ring-4 focus:ring-secondary/5" />
								</label>
							</div>
							<div class="grid gap-6 md:grid-cols-2">
								<label class="block">
									<span class="text-xs font-bold uppercase tracking-[0.15em] text-primary/50">Teléfono opcional</span>
									<input name="phone" type="tel" placeholder="600 000 000" class="mt-2.5 w-full rounded-xl border border-primary/8 bg-bg-light/50 px-5 py-4 text-primary outline-none transition-all duration-300 placeholder:text-text-muted/40 focus:border-secondary/40 focus:bg-white focus:ring-4 focus:ring-secondary/5" />
								</label>
								<label class="block">
									<span class="text-xs font-bold uppercase tracking-[0.15em] text-primary/50">Oposición de interés</span>
									<div class="relative">
										<select name="oposicion" class="mt-2.5 w-full appearance-none rounded-xl border border-primary/8 bg-bg-light/50 px-5 py-4 text-primary outline-none transition-all duration-300 focus:border-secondary/40 focus:bg-white focus:ring-4 focus:ring-secondary/5">
											<option>Administrativo del Estado AGE C1</option>
											<option>Administrativo Seguridad Social C1</option>
											<option>Pack AGE + Seguridad Social</option>
											<option>Tengo una duda general</option>
										</select>
										<div class="pointer-events-none absolute inset-y-0 right-0 mt-2.5 flex items-center px-4 text-primary/40">
											<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
										</div>
									</div>
								</label>
							</div>
							<label class="block">
								<span class="text-xs font-bold uppercase tracking-[0.15em] text-primary/50">¿En qué puedo ayudarte?</span>
								<textarea name="message" required rows="5" placeholder="Cuéntame un poco sobre tu situación..." class="mt-2.5 w-full resize-none rounded-xl border border-primary/8 bg-bg-light/50 px-5 py-4 text-primary outline-none transition-all duration-300 placeholder:text-text-muted/40 focus:border-secondary/40 focus:bg-white focus:ring-4 focus:ring-secondary/5"></textarea>
							</label>
							<label class="flex items-center gap-3 text-sm text-text-muted/80">
								<input type="checkbox" required class="h-4.5 w-4.5 shrink-0 rounded border-primary/20 accent-secondary transition-all focus:ring-2 focus:ring-secondary/20" />
								<span class="leading-relaxed">Acepto el tratamiento de mis datos según la <a href="/politica-privacidad/" class="font-semibold text-secondary no-underline transition-colors hover:text-accent">política de privacidad</a>.</span>
							</label>
							<button type="submit" class="w-full rounded-xl bg-secondary py-4.5 text-base font-bold text-white shadow-button transition-all duration-300 hover:bg-primary hover:shadow-premium-hover active:scale-[0.98]">
								Enviar mi consulta
							</button>
						</form>
						<div id="contact-success" class="hidden py-8 text-center animate-in fade-in zoom-in duration-700">
							<div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-full bg-secondary text-white shadow-button">
								<svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
							</div>
							<p class="text-2xl font-extrabold tracking-tight text-secondary">¡Mensaje enviado!</p>
							<p class="mt-3 font-medium text-primary/80">Mª Carmen te responderá en menos de 24 h.</p>
						</div>
						<div id="contact-error" class="hidden rounded-2xl border border-accent/25 bg-accent/10 p-6 text-center text-sm font-semibold text-primary">
							No se ha podido enviar el mensaje. Puedes escribirme directamente a infomcoposiciones@gmail.com.
						</div>
					</div>

					<aside class="flex flex-col">
						<div class="flex h-full flex-col rounded-2xl border border-primary/10 bg-white p-8 shadow-premium md:p-10">
							<span class="h-1 w-14 rounded-full bg-secondary"></span>
							<h2 class="mt-6 text-xl font-extrabold tracking-tight text-primary">Contacto directo</h2>
							<p class="mt-2 text-sm leading-relaxed text-text-muted/80">Si lo prefieres, puedes escribir directamente y te responderé en días laborables.</p>

							<div class="mt-8 divide-y divide-primary/10 border-y border-primary/10">
								<a href="mailto:infomcoposiciones@gmail.com" class="group flex items-center gap-4 py-5 no-underline">
									<span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-bg-light text-secondary transition-colors duration-300 group-hover:bg-secondary group-hover:text-white">
										<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 7 9 6 9-6" /><path d="M4 5h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Z" /></svg>
									</span>
									<span class="min-w-0">
										<span class="block text-[10px] font-bold uppercase tracking-widest text-primary/45">Email</span>
										<span class="block truncate text-sm font-semibold text-primary transition-colors group-hover:text-secondary">infomcoposiciones@gmail.com</span>
									</span>
								</a>
								<a href="https://wa.me/34642170664" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-4 py-5 no-underline">
									<span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-bg-light text-secondary transition-colors duration-300 group-hover:bg-secondary group-hover:text-white">
										<svg class="h-5.5 w-5.5" viewBox="0 0 32 32" fill="none" aria-hidden="true"><path fill="currentColor" d="M16.02 3C8.86 3 3.03 8.82 3.03 15.98c0 2.28.6 4.52 1.73 6.49L3 29l6.68-1.76a12.88 12.88 0 0 0 6.34 1.64C23.18 28.88 29 23.06 29 15.9 29 8.76 23.18 3 16.02 3Zm0 23.7c-1.95 0-3.86-.52-5.54-1.5l-.39-.23-3.98 1.04 1.06-3.87-.26-.4a10.7 10.7 0 1 1 9.11 4.96Z" /><path fill="currentColor" d="M21.92 18.84c-.32-.16-1.9-.94-2.2-1.05-.3-.11-.52-.16-.74.16-.22.32-.85 1.05-1.04 1.27-.19.22-.38.24-.7.08-.32-.16-1.36-.5-2.6-1.6-.96-.86-1.6-1.92-1.8-2.24-.19-.32-.02-.5.14-.66.14-.14.32-.38.48-.56.16-.19.22-.32.32-.53.11-.22.05-.4-.03-.56-.08-.16-.74-1.78-1.02-2.44-.27-.64-.54-.55-.74-.56h-.63c-.22 0-.56.08-.85.4-.3.32-1.12 1.1-1.12 2.68s1.15 3.1 1.31 3.32c.16.22 2.26 3.46 5.48 4.85.77.33 1.37.53 1.84.68.77.25 1.47.21 2.02.13.62-.09 1.9-.78 2.17-1.53.27-.75.27-1.39.19-1.53-.08-.14-.3-.22-.62-.38Z" /></svg>
									</span>
									<span>
										<span class="block text-[10px] font-bold uppercase tracking-widest text-primary/45">WhatsApp</span>
										<span class="block text-sm font-semibold text-primary transition-colors group-hover:text-secondary">642 170 664</span>
									</span>
								</a>
							</div>

							<div class="mt-auto pt-8">
								<p class="border-l-4 border-secondary pl-5 text-base font-bold leading-snug text-primary">"La mejor inversión es el tiempo que dedicas a prepararte bien."</p>
								<p class="mt-3 pl-6 text-xs font-semibold text-text-muted/60">— Mª Carmen, preparadora</p>
							</div>
						</div>
					</aside>
				</div>
			</div>
		</section>
	</main>
	<script>
		const form = document.getElementById('contact-form');
		const success = document.getElementById('contact-success');
		const error = document.getElementById('contact-error');
		const submitButton = form?.querySelector('button[type="submit"]');
		const emailjsServiceId = 'service_t4fkzpg';
		const emailjsTemplateId = 'template_t0wwp0e';
		const emailjsPublicKey = '1vi1fsa21HJtjOfi3';

		form?.addEventListener('submit', async (event) => {
			event.preventDefault();
			if (!(form instanceof HTMLFormElement) || !form.reportValidity()) return;

			const formData = new FormData(form);
			const name = String(formData.get('name') ?? '');
			const email = String(formData.get('email') ?? '');
			const phone = String(formData.get('phone') ?? '');
			const oposicion = String(formData.get('oposicion') ?? '');
			const message = String(formData.get('message') ?? '');

			success?.classList.add('hidden');
			error?.classList.add('hidden');
			submitButton?.setAttribute('disabled', 'true');

			try {
				const response = await fetch('https://api.emailjs.com/api/v1.0/email/send', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({
						service_id: emailjsServiceId,
						template_id: emailjsTemplateId,
						user_id: emailjsPublicKey,
						template_params: {
							name,
							email,
							phone,
							message: `Oposición de interés: ${oposicion}\n\n${message}`,
							oposicion,
							nombre: name,
							telefono: phone,
							mensaje: message,
							reply_to: email,
						},
					}),
				});
				if (!response.ok) throw new Error('EmailJS request failed');
				form.classList.add('hidden');
				success?.classList.remove('hidden');
			} catch {
				error?.classList.remove('hidden');
			} finally {
				submitButton?.removeAttribute('disabled');
			}
		});
	</script>
</BaseLayout>
