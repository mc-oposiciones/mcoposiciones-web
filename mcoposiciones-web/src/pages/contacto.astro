---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---
<BaseLayout
	title="Contacto — MC Oposiciones | Preparadora AGE y Seguridad Social"
	description="Contacta con Mª Carmen para resolver tus dudas sobre las oposiciones de AGE o Seguridad Social. Respuesta en menos de 24 horas en días laborables."
	canonicalUrl="https://mcoposiciones.com/contacto/"
	noindex={true}
>
	<main class="overflow-x-hidden pt-24">
		<section class="px-4 py-16 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Contacto', href: '' }]} />
				<header class="mb-12 mt-12 max-w-4xl">
					<p class="text-sm font-extrabold uppercase tracking-[0.2em] text-secondary/90">Estamos aquí para ayudarte</p>
					<h1 class="mt-4 text-4xl font-extrabold leading-tight tracking-tight text-primary md:text-6xl">Contacta con Mª Carmen</h1>
					<p class="mt-6 max-w-3xl text-lg leading-relaxed text-text-muted/90 md:text-xl">
						Resuelvo tus dudas sobre la preparación, los grupos y el temario en menos de 24 horas (días laborables).
					</p>
				</header>

				<div class="grid gap-8 lg:grid-cols-[1fr_380px] lg:items-stretch">
					<div class="rounded-2xl border border-primary/5 bg-white p-8 md:p-12 shadow-premium">
						<form id="contact-form" action="https://formspree.io/f/[ENDPOINT]" method="POST" class="space-y-7">
							<!-- TODO: Sustituir [ENDPOINT] por el endpoint real de Formspree. -->
							<div class="grid gap-6 md:grid-cols-2">
								<label class="block">
									<span class="text-xs font-bold uppercase tracking-[0.15em] text-primary/50">Nombre completo</span>
									<input name="nombre" type="text" required placeholder="Tu nombre" class="mt-2.5 w-full rounded-xl border border-primary/8 bg-bg-light/50 px-5 py-4 text-primary outline-none transition-all duration-300 focus:border-secondary/40 focus:bg-white focus:ring-4 focus:ring-secondary/5 placeholder:text-text-muted/40" />
								</label>
								<label class="block">
									<span class="text-xs font-bold uppercase tracking-[0.15em] text-primary/50">Email de contacto</span>
									<input name="email" type="email" required placeholder="ejemplo@correo.com" class="mt-2.5 w-full rounded-xl border border-primary/8 bg-bg-light/50 px-5 py-4 text-primary outline-none transition-all duration-300 focus:border-secondary/40 focus:bg-white focus:ring-4 focus:ring-secondary/5 placeholder:text-text-muted/40" />
								</label>
							</div>
							<div class="grid gap-6 md:grid-cols-2">
								<label class="block">
									<span class="text-xs font-bold uppercase tracking-[0.15em] text-primary/50">Teléfono (opcional)</span>
									<input name="telefono" type="tel" placeholder="600 000 000" class="mt-2.5 w-full rounded-xl border border-primary/8 bg-bg-light/50 px-5 py-4 text-primary outline-none transition-all duration-300 focus:border-secondary/40 focus:bg-white focus:ring-4 focus:ring-secondary/5 placeholder:text-text-muted/40" />
								</label>
								<label class="block">
									<span class="text-xs font-bold uppercase tracking-[0.15em] text-primary/50">Oposición de interés</span>
									<div class="relative">
										<select name="oposicion" class="mt-2.5 w-full appearance-none rounded-xl border border-primary/8 bg-bg-light/50 px-5 py-4 text-primary outline-none transition-all duration-300 focus:border-secondary/40 focus:bg-white focus:ring-4 focus:ring-secondary/5">
											<option>Administrativo del Estado (AGE C1)</option>
											<option>Administrativo Seguridad Social C1</option>
											<option>Pack AGE + Seguridad Social</option>
											<option>Tengo una duda general</option>
										</select>
										<div class="pointer-events-none absolute inset-y-0 right-0 mt-2.5 flex items-center px-4 text-primary/40">
											<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
										</div>
									</div>
								</label>
							</div>
							<label class="block">
								<span class="text-xs font-bold uppercase tracking-[0.15em] text-primary/50">¿En qué puedo ayudarte?</span>
								<textarea name="mensaje" required minlength="10" rows="5" placeholder="Cuéntame un poco sobre tu situación..." class="mt-2.5 w-full rounded-xl border border-primary/8 bg-bg-light/50 px-5 py-4 text-primary outline-none transition-all duration-300 focus:border-secondary/40 focus:bg-white focus:ring-4 focus:ring-secondary/5 placeholder:text-text-muted/40 resize-none"></textarea>
							</label>
							<label class="flex items-start gap-3 text-sm text-text-muted/80">
								<input type="checkbox" required class="mt-1 h-5 w-5 shrink-0 rounded border-primary/15 text-secondary focus:ring-secondary/20 transition-all" />
								<span class="leading-relaxed">Acepto el tratamiento de mis datos según la <a href="/politica-privacidad/" class="font-semibold text-secondary no-underline hover:text-accent transition-colors">política de privacidad</a>.</span>
							</label>
							<button type="submit" class="w-full rounded-xl bg-secondary py-4.5 text-base font-bold text-white shadow-button transition-all duration-300 hover:bg-primary hover:shadow-premium-hover active:scale-[0.98]">
								Enviar mi consulta
							</button>
						</form>
						<div id="contact-success" class="hidden rounded-2xl bg-secondary/5 border border-secondary/20 p-10 text-center animate-in fade-in zoom-in duration-700">
							<div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-secondary text-white shadow-button mb-5">
								<svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
							</div>
							<p class="text-2xl font-extrabold tracking-tight text-secondary">¡Mensaje enviado!</p>
							<p class="mt-3 text-primary/80 font-medium">Mª Carmen te responderá en menos de 24h.</p>
						</div>
					</div>

					<aside class="flex flex-col">
						<div class="rounded-2xl border border-primary/5 bg-gradient-to-br from-primary/5 to-bg-light/40 p-8 md:p-10 shadow-premium flex flex-col justify-between h-full">
							<div>
								<h2 class="text-lg font-extrabold tracking-tight text-primary">Contacto directo</h2>
								<p class="mt-2 text-sm text-text-muted/70">Si lo prefieres, puedes escribir directamente:</p>

								<div class="mt-8 space-y-6">
									<a href="mailto:infomcoposiciones@gmail.com" class="group flex items-center gap-4 no-underline">
										<span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-bg-light text-secondary transition-all duration-300 group-hover:bg-secondary group-hover:text-white group-hover:shadow-button">
											<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 7 9 6 9-6M4 5h16c1.1 0 2 .9 2 2v10c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V7c0-1.1.9-2 2-2z"/></svg>
										</span>
										<div class="flex flex-col">
											<span class="text-[10px] font-bold uppercase tracking-widest text-primary/40">Email</span>
											<span class="text-sm font-semibold text-primary group-hover:text-secondary transition-colors truncate">infomcoposiciones@gmail.com</span>
										</div>
									</a>
									<a href="tel:+34642170664" class="group flex items-center gap-4 no-underline">
										<span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-bg-light text-secondary transition-all duration-300 group-hover:bg-secondary group-hover:text-white group-hover:shadow-button">
											<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
										</span>
										<div class="flex flex-col">
											<span class="text-[10px] font-bold uppercase tracking-widest text-primary/40">Teléfono</span>
											<span class="text-sm font-semibold text-primary group-hover:text-secondary transition-colors">642 170 664</span>
										</div>
									</a>
								</div>

								<div class="mt-8 pt-8 border-t border-primary/5">
									<div class="rounded-2xl bg-gradient-to-br from-secondary/5 via-bg-light to-accent/5 p-6 border border-secondary/10">
										<svg class="h-6 w-6 text-secondary/40 mb-3" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
										<p class="text-base font-bold leading-snug text-primary">"La mejor inversión es el tiempo que dedicas a prepararte bien."</p>
										<p class="mt-3 text-xs font-semibold text-text-muted/60">— Mª Carmen, preparadora</p>
									</div>
								</div>
							</div>
						</div>
					</aside>
				</div>
			</div>
		</section>
	</main>
	<script>
		const form = document.getElementById('contact-form');
		const success = document.getElementById('contact-success');
		form?.addEventListener('submit', async (event) => {
			event.preventDefault();
			const response = await fetch(form.action, { method: 'POST', body: new FormData(form), headers: { Accept: 'application/json' } });
			if (response.ok) {
				form.classList.add('hidden');
				success?.classList.remove('hidden');
			} else {
				form.submit();
			}
		});
	</script>
</BaseLayout>
