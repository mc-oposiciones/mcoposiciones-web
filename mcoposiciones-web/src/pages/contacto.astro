---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
	title="Contacto — MC Oposiciones | Preparadora AGE y Seguridad Social"
	description="Contacta con Mª Carmen para resolver tus dudas sobre las oposiciones de AGE o Seguridad Social. Respuesta en menos de 24 horas en días laborables."
	canonicalUrl="https://mcoposiciones.com/contacto/"
	noindex={true}
>
	<main class="overflow-x-hidden pt-24">
		<section class="px-4 py-16 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-6xl">
				<div class="grid gap-16 lg:grid-cols-[1fr_400px]">
					<div>
						<h1 class="text-4xl font-extrabold text-primary md:text-6xl">Contacta con Mª Carmen</h1>
						<p class="mt-6 text-lg leading-relaxed text-text-muted">
							Resuelvo tus dudas sobre la preparación, los grupos y el temario en menos de 24 horas (días laborables).
						</p>

						<form id="contact-form" action="https://formspree.io/f/[ENDPOINT]" method="POST" class="mt-12 space-y-6 rounded-[2rem] border border-primary/5 bg-white p-8 shadow-premium md:p-10">
							<!-- TODO: Sustituir [ENDPOINT] por el endpoint real de Formspree. -->
							<div class="grid gap-6 md:grid-cols-2">
								<label class="block">
									<span class="text-sm font-bold uppercase tracking-wider text-primary">Nombre completo</span>
									<input name="nombre" type="text" required placeholder="Tu nombre" class="mt-3 w-full rounded-2xl border border-primary/10 bg-bg-light/30 px-5 py-4 text-primary outline-none transition-all focus:border-secondary focus:bg-white focus:ring-4 focus:ring-secondary/10" />
								</label>
								<label class="block">
									<span class="text-sm font-bold uppercase tracking-wider text-primary">Email de contacto</span>
									<input name="email" type="email" required placeholder="ejemplo@correo.com" class="mt-3 w-full rounded-2xl border border-primary/10 bg-bg-light/30 px-5 py-4 text-primary outline-none transition-all focus:border-secondary focus:bg-white focus:ring-4 focus:ring-secondary/10" />
								</label>
							</div>
							<div class="grid gap-6 md:grid-cols-2">
								<label class="block">
									<span class="text-sm font-bold uppercase tracking-wider text-primary">Teléfono (opcional)</span>
									<input name="telefono" type="tel" placeholder="600 000 000" class="mt-3 w-full rounded-2xl border border-primary/10 bg-bg-light/30 px-5 py-4 text-primary outline-none transition-all focus:border-secondary focus:bg-white focus:ring-4 focus:ring-secondary/10" />
								</label>
								<label class="block">
									<span class="text-sm font-bold uppercase tracking-wider text-primary">Oposición de interés</span>
									<select name="oposicion" class="mt-3 w-full rounded-2xl border border-primary/10 bg-bg-light/30 px-5 py-4 text-primary outline-none transition-all focus:border-secondary focus:bg-white focus:ring-4 focus:ring-secondary/10">
										<option>Administrativo del Estado (AGE C1)</option>
										<option>Administrativo Seguridad Social C1</option>
										<option>Pack AGE + Seguridad Social</option>
										<option>Tengo una duda general</option>
									</select>
								</label>
							</div>
							<label class="block">
								<span class="text-sm font-bold uppercase tracking-wider text-primary">¿En qué puedo ayudarte?</span>
								<textarea name="mensaje" required minlength="10" rows="6" placeholder="Cuéntame un poco sobre tu situación..." class="mt-3 w-full rounded-2xl border border-primary/10 bg-bg-light/30 px-5 py-4 text-primary outline-none transition-all focus:border-secondary focus:bg-white focus:ring-4 focus:ring-secondary/10"></textarea>
							</label>
							<label class="flex items-center gap-3 text-sm text-text-muted">
								<input type="checkbox" required class="h-5 w-5 rounded-lg border-primary/20 text-secondary focus:ring-secondary" />
								<span>Acepto la <a href="/politica-privacidad/" class="font-bold text-secondary no-underline">política de privacidad</a>.</span>
							</label>
							<button type="submit" class="w-full rounded-2xl bg-secondary py-5 text-lg font-bold text-white shadow-premium transition-all hover:-translate-y-1 hover:bg-accent hover:shadow-premium-hover active:scale-95">
								Enviar mi consulta
							</button>
						</form>
						<div id="contact-success" class="mt-12 hidden rounded-[2rem] bg-secondary/10 border border-secondary/20 p-8 text-center animate-in fade-in zoom-in duration-500">
							<p class="text-2xl font-extrabold text-secondary">¡Mensaje enviado!</p>
							<p class="mt-3 text-primary font-medium">Gracias por contactar. Mª Carmen te responderá personalmente en menos de 24h.</p>
						</div>
					</div>

					<aside class="space-y-8">
						<div class="rounded-[2.5rem] border border-primary/5 bg-white p-10 shadow-premium">
							<h2 class="text-2xl font-extrabold text-primary">Contacto directo</h2>
							<p class="mt-4 text-sm text-text-muted">Si lo prefieres, puedes escribir directamente a través de estos canales:</p>
							<div class="mt-10 space-y-6">
								<a href="mailto:infomcoposiciones@gmail.com" class="group flex items-center gap-4 no-underline">
									<span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-bg-light text-secondary transition-colors group-hover:bg-secondary group-hover:text-white">
										<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 7 9 6 9-6M4 5h16c1.1 0 2 .9 2 2v10c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V7c0-1.1.9-2 2-2z"/></svg>
									</span>
									<span class="font-bold text-primary group-hover:text-secondary">infomcoposiciones@gmail.com</span>
								</a>
								<a href="tel:+34642170664" class="group flex items-center gap-4 no-underline">
									<span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-bg-light text-secondary transition-colors group-hover:bg-secondary group-hover:text-white">
										<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
									</span>
									<span class="font-bold text-primary group-hover:text-secondary">642 170 664</span>
								</a>
							</div>
						</div>
						<div class="rounded-[2.5rem] bg-primary p-10 text-white shadow-premium">
							<h3 class="text-xl font-extrabold italic">"La mejor inversión es el tiempo que dedicas a prepararte bien."</h3>
							<p class="mt-6 text-sm text-white/70">— Mª Carmen, preparadora.</p>
						</div>
					</aside>
				</div>
			</div>
		</section>
	</main>
	<script>
		const form = document.getElementById('contact-form');
		const success = document.getElementById('contact-success');
		form?.addEventListener('submit', async (event) => {
			event.preventDefault();
			const response = await fetch(form.action, { method: 'POST', body: new FormData(form), headers: { Accept: 'application/json' } });
			if (response.ok) {
				form.classList.add('hidden');
				success?.classList.remove('hidden');
			} else {
				form.submit();
			}
		});
	</script>
</BaseLayout>
