---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTABanner from '../components/CTABanner.astro';
import { createPricingPageSchema } from '../lib/schema';

const schemaJson = JSON.stringify(createPricingPageSchema());
const plans = [
	{
		name: 'Mensual',
		price: '100€',
		detail: '/mes',
		bestFor: 'Ritmo flexible',
		description: 'Para empezar sin permanencia y mantener el control del ritmo de estudio.',
		items: ['Clases online en directo', 'Grabaciones disponibles', 'Material y test por tema'],
		href: '/contacto/',
	},
	{
		name: 'Completo',
		price: '475€',
		detail: 'pago único',
		bestFor: 'Preparación estable',
		description: 'La opción más rentable si tienes claro que vas a preparar hasta el examen.',
		items: ['Acceso hasta el examen', 'Material completo incluido', 'Simulacros de examen real'],
		href: '/contacto/',
		highlight: true,
	},
	{
		name: 'Pack AGE + SS',
		price: 'Consultar',
		detail: 'doble vía',
		bestFor: 'Maximizar opciones',
		description: 'Preparación conjunta para aprovechar el temario común y abrir dos oportunidades.',
		items: ['Planificación conjunta', 'Temario común optimizado', 'Ahorro de tiempo de estudio'],
		href: '/preparar-age-y-seguridad-social/',
	},
	{
		name: 'Parte general',
		price: '250€',
		detail: 'pago único',
		bestFor: 'Refuerzo concreto',
		description: 'Bloques comunes para AGE o Seguridad Social cuando no necesitas el curso completo.',
		items: ['Temario general', 'Batería de test', 'Clases grabadas'],
		href: '/contacto/',
	},
	{
		name: 'Parte específica SS',
		price: '300€',
		detail: 'pago único',
		bestFor: 'Alumnos que vienen de AGE',
		description: 'Los temas propios de Seguridad Social y el trabajo del supuesto práctico.',
		items: ['Legislación específica SS', 'Supuestos prácticos', 'Esquemas de apoyo'],
		href: '/contacto/',
	},
];

const faqItems = [
	{ question: '¿Hay permanencia?', answer: 'No. La modalidad mensual no tiene compromiso de permanencia.' },
	{ question: '¿Qué incluye el pago único?', answer: 'Incluye acceso al curso, clases en directo, grabaciones, material, test y simulacros hasta el examen.' },
	{ question: '¿Puedo cambiar de modalidad?', answer: 'Sí, puedes consultar tu caso con Mª Carmen para elegir la modalidad que más te convenga.' },
];
---
<BaseLayout
	title="Cursos y Precios — Preparación Oposiciones AGE y Seguridad Social | MC Oposiciones"
	description="Consulta los cursos disponibles para preparar las oposiciones de Administrativo del Estado y Seguridad Social. Desde 100€/mes o 475€ pago único. Sin compromiso de permanencia."
	canonicalUrl="https://mcoposiciones.com/cursos-precios/"
	schemaJson={schemaJson}
>
	<main class="overflow-x-hidden pt-20">
		<section class="px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
			<div class="mx-auto max-w-7xl">
				<Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Cursos y precios', href: '' }]} />
				<div class="mt-12 grid gap-12 lg:grid-cols-[1fr_24rem] lg:items-center">
					<div class="max-w-4xl">
						<p class="text-sm font-bold uppercase tracking-[0.2em] text-secondary/90">Modalidades de preparación</p>
						<h1 class="mt-6 text-4xl font-extrabold leading-[1.15] text-primary md:text-6xl">Planes y precios</h1>
						<p class="mt-8 text-lg leading-relaxed text-text-muted/90 md:text-xl lg:max-w-2xl">
							Todas las modalidades incluyen clases en directo, material actualizado y acompañamiento personalizado. Elige el formato que mejor encaje con tu ritmo.
						</p>
					</div>
					<div class="rounded-[2rem] border border-primary/5 bg-white p-8 shadow-premium md:p-10">
						<p class="text-xs font-bold uppercase tracking-widest text-primary/40">Desde solo</p>
						<div class="mt-4 flex items-baseline gap-2">
							<span class="text-5xl font-black tracking-tighter text-primary">100€</span>
							<span class="text-lg font-bold text-text-muted/60">/mes</span>
						</div>
						<p class="mt-4 text-sm leading-relaxed text-text-muted/80 italic">Sin permanencia mínima. Cancela cuando quieras.</p>
					</div>
				</div>
			</div>
		</section>

		<section class="bg-white/50 px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="divide-y divide-primary/5 overflow-hidden rounded-[2.5rem] border border-primary/5 bg-white shadow-premium">
					{plans.map((plan) => (
						<article class={`grid gap-8 p-8 md:grid-cols-[1.4fr_0.8fr_1fr_auto] md:items-center md:p-12 transition-colors duration-500 hover:bg-secondary/[0.02] ${plan.highlight ? 'bg-secondary/[0.04]' : ''}`}>
							<div class="max-w-md">
								<div class="flex flex-wrap items-center gap-3">
									<h2 class="text-2xl font-extrabold tracking-tight text-primary">{plan.name}</h2>
									{plan.highlight && (
										<span class="rounded-full bg-secondary/15 border border-secondary/30 px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-secondary">Más popular</span>
									)}
								</div>
								<p class="mt-4 text-base leading-relaxed text-text-muted/90">{plan.description}</p>
							</div>
							<div>
								<p class="text-[10px] font-bold uppercase tracking-widest text-primary/40">{plan.bestFor}</p>
								<div class="mt-2 flex items-baseline gap-1">
									<p class="text-4xl font-black tracking-tighter text-primary">{plan.price}</p>
									<p class="text-sm font-bold text-text-muted/60">{plan.detail}</p>
								</div>
							</div>
							<ul class="grid gap-3 py-2">
								{plan.items.map((item) => (
									<li class="flex items-center gap-3 text-sm font-medium text-text-main/80">
										<span class="h-1.5 w-1.5 shrink-0 rounded-full bg-secondary shadow-[0_0_8px_rgba(42,157,143,0.4)]"></span>
										<span>{item}</span>
									</li>
								))}
							</ul>
							<div class="flex">
								<a href={plan.href} class={`inline-flex w-full justify-center rounded-xl px-8 py-4 text-sm font-bold no-underline shadow-button transition-all duration-300 hover:scale-[1.03] active:scale-[0.97] ${plan.highlight ? 'bg-secondary text-white hover:bg-primary' : 'border border-secondary/30 text-secondary hover:bg-secondary/5'}`}>
									Consultar plan
								</a>
							</div>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="mb-16 max-w-3xl">
					<h2 class="text-3xl font-extrabold tracking-tight text-primary md:text-5xl">Comparativa detallada</h2>
					<p class="mt-5 text-lg leading-relaxed text-text-muted/90">Analiza qué incluye cada modalidad para tomar la decisión que mejor se adapte a tu preparación.</p>
				</div>
				<div class="overflow-hidden rounded-3xl border border-primary/5 bg-white shadow-premium">
					<div class="overflow-x-auto">
						<table class="w-full text-left">
							<thead>
								<tr class="bg-bg-light/40 border-b border-primary/5">
									<th class="p-8 text-sm font-bold uppercase tracking-widest text-primary/60">Concepto</th>
									<th class="p-8 text-sm font-extrabold text-primary md:text-lg">Mensual</th>
									<th class="p-8 text-sm font-extrabold text-primary md:text-lg">Pago único</th>
									<th class="p-8 text-sm font-extrabold text-primary md:text-lg">Módulos</th>
								</tr>
							</thead>
							<tbody class="divide-y divide-primary/5">
								{[
									{ label: 'Clases en directo', m: 'Sí', u: 'Sí', mo: 'Grabadas' },
									{ label: 'Resolución de dudas', m: 'Directa', u: 'Prioritaria', mo: 'Email' },
									{ label: 'Acceso al material', m: 'Mes a mes', u: 'Hasta el examen', mo: 'Por módulo' },
									{ label: 'Simulacros examen', m: 'Sí', u: 'Sí', mo: 'No incluidos' }
								].map((row) => (
									<tr class="transition-colors duration-200 hover:bg-bg-light/20">
										<td class="p-8 font-bold text-primary">{row.label}</td>
										<td class="p-8 text-secondary font-semibold">{row.m}</td>
										<td class="p-8 text-secondary font-semibold">{row.u}</td>
										<td class="p-8 text-text-muted/70">{row.mo}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				</div>
			</div>
		</section>

		<section class="bg-white/50 px-4 py-20 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-4xl">
				<h2 class="mb-10 text-center text-3xl font-extrabold text-primary md:text-4xl">Dudas sobre las modalidades</h2>
				<FAQAccordion items={faqItems} />
			</div>

			<div class="mx-auto mt-16 max-w-5xl">
				<CTABanner
					title="¿No sabes qué plan elegir?"
					subtitle="Cuéntame tu situación y te recomendaré la opción más razonable según tiempo disponible, experiencia previa y oposición objetivo."
					ctaText="Consultar con Mª Carmen"
					ctaHref="/contacto/"
					variant="primary"
				/>
			</div>
		</section>
	</main>
</BaseLayout>
