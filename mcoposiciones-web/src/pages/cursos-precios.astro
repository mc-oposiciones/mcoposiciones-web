---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTABanner from '../components/CTABanner.astro';
import { createPricingPageSchema } from '../lib/schema';

const schemaJson = JSON.stringify(createPricingPageSchema());
const plans = [
	{
		name: 'Mensual',
		price: '100€',
		detail: '/mes',
		bestFor: 'Ritmo flexible',
		description: 'Para empezar sin permanencia y mantener el control del ritmo de estudio.',
		items: ['Clases online en directo', 'Grabaciones disponibles', 'Material y test por tema'],
		href: '/contacto/',
	},
	{
		name: 'Completo',
		price: '475€',
		detail: 'pago único',
		bestFor: 'Preparación estable',
		description: 'La opción más rentable si tienes claro que vas a preparar hasta el examen.',
		items: ['Acceso hasta el examen', 'Material completo incluido', 'Simulacros de examen real'],
		href: '/contacto/',
		highlight: true,
	},
	{
		name: 'Pack AGE + SS',
		price: 'Consultar',
		detail: 'doble vía',
		bestFor: 'Maximizar opciones',
		description: 'Preparación conjunta para aprovechar el temario común y abrir dos oportunidades.',
		items: ['Planificación conjunta', 'Temario común optimizado', 'Ahorro de tiempo de estudio'],
		href: '/preparar-age-y-seguridad-social/',
	},
	{
		name: 'Parte general',
		price: '250€',
		detail: 'pago único',
		bestFor: 'Refuerzo concreto',
		description: 'Bloques comunes para AGE o Seguridad Social cuando no necesitas el curso completo.',
		items: ['Temario general', 'Batería de test', 'Clases grabadas'],
		href: '/contacto/',
	},
	{
		name: 'Parte específica SS',
		price: '300€',
		detail: 'pago único',
		bestFor: 'Alumnos que vienen de AGE',
		description: 'Los temas propios de Seguridad Social y el trabajo del supuesto práctico.',
		items: ['Legislación específica SS', 'Supuestos prácticos', 'Esquemas de apoyo'],
		href: '/contacto/',
	},
];

const faqItems = [
	{ question: '¿Hay permanencia?', answer: 'No. La modalidad mensual no tiene compromiso de permanencia.' },
	{ question: '¿Qué incluye el pago único?', answer: 'Incluye acceso al curso, clases en directo, grabaciones, material, test y simulacros hasta el examen.' },
	{ question: '¿Puedo cambiar de modalidad?', answer: 'Sí, puedes consultar tu caso con Mª Carmen para elegir la modalidad que más te convenga.' },
];
---
<BaseLayout
	title="Cursos y Precios — Preparación Oposiciones AGE y Seguridad Social | MC Oposiciones"
	description="Consulta los cursos disponibles para preparar las oposiciones de Administrativo del Estado y Seguridad Social. Desde 100€/mes o 475€ pago único. Sin compromiso de permanencia."
	canonicalUrl="https://mcoposiciones.com/cursos-precios/"
	schemaJson={schemaJson}
>
	<main class="overflow-x-hidden pt-20">
		<section class="px-4 py-16 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Cursos y precios', href: '' }]} />
				<div class="mt-10 grid gap-10 lg:grid-cols-[1fr_22rem] lg:items-end">
					<div class="max-w-4xl">
						<p class="text-sm font-bold uppercase tracking-widest text-secondary">Modalidades de preparación</p>
						<h1 class="mt-4 text-4xl font-extrabold leading-tight text-primary md:text-6xl">Cursos disponibles y precios</h1>
						<p class="mt-6 text-lg leading-relaxed text-text-muted md:text-xl">
							Elige una preparación completa, mensual o por módulos. Todas las modalidades mantienen el mismo criterio: clases claras, material actualizado y acompañamiento directo.
						</p>
					</div>
					<div class="rounded-2xl border border-primary/10 bg-white p-6">
						<p class="text-sm font-bold uppercase tracking-widest text-primary/60">Desde</p>
						<p class="mt-3 text-4xl font-extrabold text-primary">100€<span class="text-base font-bold text-text-muted">/mes</span></p>
						<p class="mt-3 text-sm leading-relaxed text-text-muted">Sin permanencia en la modalidad mensual.</p>
					</div>
				</div>
			</div>
		</section>

		<section class="px-4 py-12 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="overflow-hidden rounded-2xl border border-primary/10 bg-white">
					{plans.map((plan) => (
						<article class={`grid gap-6 border-b border-primary/10 p-6 last:border-b-0 md:grid-cols-[1.2fr_0.8fr_1fr_auto] md:items-center md:p-8 ${plan.highlight ? 'bg-secondary/5' : ''}`}>
							<div>
								<div class="flex flex-wrap items-center gap-3">
									<h2 class="text-2xl font-extrabold text-primary">{plan.name}</h2>
									{plan.highlight && (
										<span class="rounded-full bg-secondary px-3 py-1 text-xs font-bold uppercase tracking-widest text-white">Recomendado</span>
									)}
								</div>
								<p class="mt-3 leading-relaxed text-text-muted">{plan.description}</p>
							</div>
							<div>
								<p class="text-sm font-bold uppercase tracking-widest text-primary/60">{plan.bestFor}</p>
								<p class="mt-2 text-3xl font-extrabold text-primary">{plan.price}</p>
								<p class="text-sm font-bold text-text-muted">{plan.detail}</p>
							</div>
							<ul class="space-y-2 text-sm text-text-main">
								{plan.items.map((item) => (
									<li class="flex gap-2">
										<span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-secondary"></span>
										<span>{item}</span>
									</li>
								))}
							</ul>
							<a href={plan.href} class="inline-flex justify-center rounded-xl border border-secondary px-5 py-3 text-sm font-bold text-secondary no-underline transition-colors hover:bg-secondary hover:text-white">
								Consultar
							</a>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="bg-white px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="mb-12 max-w-3xl">
					<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Comparativa rápida</h2>
					<p class="mt-4 text-text-muted">La diferencia principal no está en la calidad del curso, sino en el formato de acceso que mejor encaja con tu momento.</p>
				</div>
				<div class="overflow-hidden rounded-2xl border border-primary/10 bg-white">
					<div class="overflow-x-auto">
						<table class="w-full text-left text-sm md:text-base">
							<thead>
								<tr class="bg-bg-dark/30">
									<th class="p-6 font-extrabold text-primary">Concepto</th>
									<th class="p-6 font-extrabold text-primary">Mensual</th>
									<th class="p-6 font-extrabold text-primary">Pago único</th>
									<th class="p-6 font-extrabold text-primary">Módulos</th>
								</tr>
							</thead>
							<tbody class="divide-y divide-primary/10">
								<tr>
									<td class="p-6 font-bold text-primary">Clases en directo</td>
									<td class="p-6 text-secondary">Sí</td>
									<td class="p-6 text-secondary">Sí</td>
									<td class="p-6 text-text-muted">Grabadas</td>
								</tr>
								<tr>
									<td class="p-6 font-bold text-primary">Resolución de dudas</td>
									<td class="p-6 text-secondary">Directa</td>
									<td class="p-6 text-secondary">Prioritaria</td>
									<td class="p-6 text-secondary">Email</td>
								</tr>
								<tr>
									<td class="p-6 font-bold text-primary">Acceso al material</td>
									<td class="p-6 text-text-muted">Mes a mes</td>
									<td class="p-6 font-bold text-secondary">Hasta el examen</td>
									<td class="p-6 text-text-muted">Por módulo</td>
								</tr>
								<tr>
									<td class="p-6 font-bold text-primary">Simulacros de examen</td>
									<td class="p-6 text-secondary">Sí</td>
									<td class="p-6 text-secondary">Sí</td>
									<td class="p-6 text-text-muted">No incluidos</td>
								</tr>
							</tbody>
						</table>
					</div>
				</div>
			</div>
		</section>

		<section class="px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-4xl">
				<h2 class="mb-12 text-center text-3xl font-extrabold text-primary md:text-4xl">Dudas sobre las modalidades</h2>
				<FAQAccordion items={faqItems} />
			</div>
		</section>

		<section class="px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-5xl">
				<CTABanner
					title="¿No sabes qué plan elegir?"
					subtitle="Cuéntame tu situación y te recomendaré la opción más razonable según tiempo disponible, experiencia previa y oposición objetivo."
					ctaText="Consultar con Mª Carmen"
					ctaHref="/contacto/"
					variant="primary"
				/>
			</div>
		</section>
	</main>
</BaseLayout>
