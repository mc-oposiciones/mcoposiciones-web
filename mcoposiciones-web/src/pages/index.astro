---
import BaseLayout from '../layouts/BaseLayout.astro';
import CourseCard from '../components/CourseCard.astro';
import TestimonialWidget from '../components/TestimonialWidget.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTABanner from '../components/CTABanner.astro';
import { Image } from 'astro:assets';
import mariaCarmenImage from '../assets/images/maria-carmen.jpg';
import { createHomeSchema } from '../lib/schema';

const schemaJson = JSON.stringify(createHomeSchema());

const faqItems = [
	{
		question: '¿Puedo preparar AGE y Seguridad Social a la vez?',
		answer: 'Sí, y es la opción más inteligente. El 75% del temario es idéntico. Solo necesitas aprender 13 temas adicionales de la parte específica de SS para tener doble oportunidad de plaza.',
	},
	{
		question: '¿Las clases son en directo o grabadas?',
		answer: 'Las clases son en directo por videoconferencia. Todas quedan grabadas y disponibles para que las puedas repasar cuando quieras.',
	},
	{
		question: '¿Cuánto tiempo necesito dedicar por semana?',
		answer: 'Entre 15 y 25 horas semanales según tu objetivo y fecha de examen. Mª Carmen te diseña un plan adaptado a tu disponibilidad.',
	},
	{
		question: '¿Qué pasa si se retrasa la convocatoria?',
		answer: 'Tu acceso al curso se mantiene hasta la fecha del examen oficial, independientemente de retrasos en la convocatoria.',
	},
];
---

<BaseLayout
	title="Preparadora de Oposiciones AGE y Seguridad Social Online | MC Oposiciones"
	description="Prepara las oposiciones de Administrativo del Estado (AGE C1) y Administrativo de la Seguridad Social con Mª Carmen, preparadora especializada. Clases en directo, temario actualizado 2026. ¡Nuevos grupos en septiembre!"
	canonicalUrl="https://mcoposiciones.com/"
	ogType="website"
	schemaJson={schemaJson}
>
	<main class="overflow-x-hidden pt-20">
		<!-- Hero Section -->
		<section class="relative px-4 pb-20 pt-10 sm:px-6 lg:px-8 lg:pb-32 lg:pt-20">
			<div class="mx-auto max-w-7xl">
				<div class="grid gap-12 lg:grid-cols-2 lg:items-center">
					<div class="relative z-10 max-w-2xl">
						<div class="mb-6 inline-flex items-center gap-2 rounded-full bg-secondary/10 px-4 py-1.5 text-sm font-bold tracking-wide text-secondary">
							<span class="flex h-2 w-2 rounded-full bg-secondary"></span>
							PREPARACIÓN ONLINE EN DIRECTO 2026
						</div>
						<h1 class="text-balance text-4xl font-extrabold leading-[1.1] text-primary md:text-6xl lg:text-7xl">
							Tu plaza en la AGE o Seg. Social <span class="text-secondary">está más cerca</span> de lo que crees
						</h1>
						<p class="mt-8 text-pretty text-lg leading-relaxed text-text-muted md:text-xl">
							Clases online en directo con Mª Carmen. Método especializado para Administrativo del Estado (C1) y Seguridad Social. Grupos reducidos, temario actualizado y planificación real.
						</p>
						<div class="mt-10 flex flex-col gap-4 sm:flex-row">
							<a href="/cursos-precios/" class="group relative overflow-hidden rounded-xl bg-secondary px-8 py-4 text-center font-bold text-white no-underline transition-all hover:-translate-y-1 hover:bg-accent">
								<span class="relative z-10">Ver cursos disponibles</span>
							</a>
							<a href="/clases-muestra/" class="rounded-xl border border-secondary/25 bg-white px-8 py-4 text-center font-bold text-secondary no-underline transition-all hover:-translate-y-1 hover:border-secondary hover:bg-secondary/5">
								Clase de muestra gratis
							</a>
						</div>
						<div class="mt-10 flex flex-wrap items-center gap-6">
							<div class="flex -space-x-2">
								{[1,2,3,4].map(() => (
									<div class="h-10 w-10 rounded-full border-2 border-white bg-bg-dark"></div>
								))}
								<div class="flex h-10 w-10 items-center justify-center rounded-full border-2 border-white bg-accent font-bold text-primary text-xs">+27</div>
							</div>
							<p class="text-sm font-medium text-primary">
								<span class="font-bold text-secondary">★★★★★</span> 27 reseñas 5 estrellas en Google
							</p>
						</div>
					</div>
					<div class="relative lg:ml-10">
						<div class="relative overflow-hidden rounded-2xl border border-primary/10 bg-white p-2 shadow-premium">
							<Image src={mariaCarmenImage} alt="Mª Carmen, preparadora de oposiciones" width={600} height={600} loading="eager" fetchpriority="high" class="rounded-xl object-cover" />
							<div class="absolute bottom-6 left-6 right-6 rounded-xl border border-white/30 bg-white/85 p-4 shadow-premium backdrop-blur-md">
								<p class="text-sm font-bold text-primary">Próximos grupos: Septiembre 2026</p>
								<p class="text-xs text-text-muted">Plazas limitadas por riguroso orden de inscripción</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Strategy Section -->
		<section class="bg-white px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="mx-auto max-w-4xl text-center">
						<h2 class="text-3xl font-extrabold text-primary md:text-5xl">La única preparadora que te prepara para <span class="text-secondary">ambas oposiciones</span> a la vez</h2>
						<p class="mt-8 text-lg leading-relaxed text-text-main md:text-xl">
							El 75% del temario es común. No malgastes tu tiempo estudiando lo mismo dos veces. Mi método te permite <a href="/preparar-age-y-seguridad-social/" class="font-bold text-secondary underline decoration-accent decoration-2 underline-offset-4">preparar AGE y Seguridad Social simultáneamente</a>, duplicando tus opciones de plaza con el mismo esfuerzo.
						</p>
						<div class="mt-12 grid gap-6 border-y border-primary/10 py-8 sm:grid-cols-3">
							<div>
								<div class="text-3xl font-bold text-secondary">75%</div>
								<p class="mt-2 text-sm font-bold text-primary">Temario Común</p>
							</div>
							<div>
								<div class="text-3xl font-bold text-secondary">x2</div>
								<p class="mt-2 text-sm font-bold text-primary">Oportunidades</p>
							</div>
							<div>
								<div class="text-3xl font-bold text-secondary">100%</div>
								<p class="mt-2 text-sm font-bold text-primary">Actualizado 2026</p>
							</div>
						</div>
				</div>
			</div>
		</section>

		<!-- Courses Section -->
		<section class="px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="mb-16 text-center">
					<h2 class="text-3xl font-extrabold text-primary md:text-5xl">Elige tu camino hacia la plaza</h2>
					<p class="mx-auto mt-6 max-w-2xl text-lg text-text-muted">Especialización total en los cuerpos administrativos C1 del Estado y la Seguridad Social.</p>
				</div>
				<div class="grid gap-8 lg:grid-cols-3">
					<CourseCard title="Administrativo del Estado (AGE C1)" description="2.512 plazas ofertadas. Enfoque total en el examen de 2026." price="100€" priceType="/mes" href="/oposiciones-administrativo-estado/" features={['Clases online en directo', 'Ofimática Word, Excel, Access', 'Simulacros examen real']} />
					<CourseCard title="Administrativo Seguridad Social (C1)" description="1.456 plazas. Examen previsto para junio 2026." price="100€" priceType="/mes" href="/oposiciones-seguridad-social/" features={['Sin prueba de ofimática', 'Legislación específica SS', 'Supuestos desde el día 1']} />
					<CourseCard title="Pack AGE + SS" description="La opción inteligente: dobla tus posibilidades reales." price="Precio especial" priceType="Pack" badge="RECOMENDADO" href="/preparar-age-y-seguridad-social/" features={['Temario común una vez', '13 temas específicos SS', 'Ofimática completa AGE']} />
				</div>
				<div class="mt-10 text-center text-sm font-semibold text-text-muted">
					Si buscas trato directo, también puedes ver la preparación personal para <a href="/preparadora-age/" class="font-bold">AGE</a> o <a href="/preparadora-seguridad-social/" class="font-bold">Seguridad Social</a>.
				</div>
			</div>
		</section>

		<!-- Bio Section -->
		<section class="bg-white px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="grid gap-16 lg:grid-cols-2 lg:items-center">
					<div class="order-2 lg:order-1">
						<h2 class="text-3xl font-extrabold text-primary md:text-5xl">Soy Mª Carmen, <span class="text-secondary">tu preparadora</span></h2>
						<p class="mt-8 text-lg leading-relaxed text-text-muted">
							No soy una academia masificada. Trabajo con grupos reducidos porque creo en una preparación personalizada, constante y, sobre todo, humana.
						</p>
						<p class="mt-4 text-lg leading-relaxed text-text-muted">
							Mi objetivo no es solo darte el temario, es que lo entiendas, que sepas aplicarlo y que llegues al examen con la seguridad de quien ha entrenado cada supuesto práctico mil veces.
						</p>
						<div class="mt-10">
							<a href="/preparadora-oposiciones/" class="inline-flex items-center gap-2 font-bold text-secondary no-underline transition-colors hover:text-accent">
								Conoce mi método de trabajo
								<svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" /></svg>
							</a>
						</div>
					</div>
					<div class="order-1 lg:order-2">
						<div class="aspect-square overflow-hidden rounded-2xl shadow-premium">
							<Image src={mariaCarmenImage} alt="Mª Carmen" width={500} height={500} class="h-full w-full object-cover transition-transform duration-700 hover:scale-110" />
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Blog Preview -->
		<section class="px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="mb-12 flex flex-col items-end justify-between gap-6 md:flex-row md:items-center">
					<div class="max-w-2xl">
						<h2 class="text-3xl font-extrabold text-primary md:text-5xl">Guías y recursos</h2>
						<p class="mt-4 text-lg text-text-muted">Todo lo que necesitas saber para elegir tu oposición y preparar tu examen con éxito.</p>
					</div>
					<a href="/blog/" class="rounded-xl border-2 border-secondary/10 px-6 py-3 font-bold text-secondary no-underline transition-all hover:bg-secondary hover:text-white">Ir al Blog</a>
				</div>
				<div class="grid gap-6 md:grid-cols-3">
					<a href="/blog/mejor-preparadora-age/" class="group rounded-xl border border-primary/10 bg-white p-7 no-underline shadow-premium transition-all hover:-translate-y-1 hover:border-secondary/25 hover:shadow-premium-hover">
						<p class="text-xs font-bold uppercase tracking-widest text-secondary">Guía Temario</p>
						<h3 class="mt-4 text-xl font-bold text-primary group-hover:text-secondary">Mejor preparadora AGE: como elegir bien</h3>
					</a>
					<a href="/blog/preparadora-oposiciones-seguridad-social/" class="group rounded-xl border border-primary/10 bg-white p-7 no-underline shadow-premium transition-all hover:-translate-y-1 hover:border-secondary/25 hover:shadow-premium-hover">
						<p class="text-xs font-bold uppercase tracking-widest text-secondary">Examen</p>
						<h3 class="mt-4 text-xl font-bold text-primary group-hover:text-secondary">Preparadora de Seguridad Social: que mirar</h3>
					</a>
					<a href="/blog/age-vs-seguridad-social/" class="group rounded-xl border border-primary/10 bg-white p-7 no-underline shadow-premium transition-all hover:-translate-y-1 hover:border-secondary/25 hover:shadow-premium-hover">
						<p class="text-xs font-bold uppercase tracking-widest text-secondary">Comparativa</p>
						<h3 class="mt-4 text-xl font-bold text-primary group-hover:text-secondary">¿AGE o Seguridad Social? Cuál elegir</h3>
					</a>
				</div>
			</div>
		</section>

		<!-- Testimonials -->
		<section id="opiniones" class="bg-bg-dark/30 px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="mb-16 text-center">
					<h2 class="text-3xl font-extrabold text-primary md:text-5xl">Resultados reales</h2>
					<p class="mt-4 text-lg text-text-muted">Lo que dicen los alumnos que ya han confiado en Mª Carmen.</p>
				</div>
				<div class="mx-auto max-w-[980px]">
					<TestimonialWidget />
				</div>
				<div class="mt-8 text-center">
					<p class="flex items-center justify-center gap-2 font-bold text-primary">
						<span class="text-2xl text-secondary">★★★★★</span>
						5.0 en Google Business
					</p>
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-4xl">
				<h2 class="mb-12 text-center text-3xl font-extrabold text-primary md:text-5xl">Preguntas frecuentes</h2>
				<FAQAccordion items={faqItems} />
			</div>
		</section>

		<!-- CTA -->
		<section class="px-4 pb-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<CTABanner 
					title="¿Empezamos a preparar tu plaza?" 
					subtitle="Escríbeme sin compromiso. Te resolveré todas las dudas sobre el método, los grupos y el temario." 
					ctaText="Contactar ahora" 
					ctaHref="/contacto/" 
					variant="primary" 
				/>
			</div>
		</section>
	</main>
</BaseLayout>
