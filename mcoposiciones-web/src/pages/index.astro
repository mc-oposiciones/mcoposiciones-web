---
import BaseLayout from '../layouts/BaseLayout.astro';
import TestimonialWidget from '../components/TestimonialWidget.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTABanner from '../components/CTABanner.astro';
import PreparationRouteCard from '../components/PreparationRouteCard.astro';
import { Image } from 'astro:assets';
import mariaCarmenImage from '../assets/images/maria-carmen.jpg';
import { createHomeSchema, withFAQSchema } from '../lib/schema';

const routes = [
	{
		title: 'AGE C1',
		kicker: 'Administrativo del Estado',
		text: 'Preparación completa con temario legislativo, ofimática y simulacros.',
		href: '/oposiciones-administrativo-estado/',
		cta: 'Ver AGE',
	},
	{
		title: 'Seguridad Social C1',
		kicker: 'Administrativo SS',
		text: 'Temario específico, supuesto práctico y planificación hasta el examen.',
		href: '/oposiciones-seguridad-social/',
		cta: 'Ver Seguridad Social',
	},
	{
		title: 'AGE + SS',
		kicker: 'Preparación conjunta',
		text: 'Aprovecha el temario común y amplía opciones sin duplicar el estudio.',
		href: '/preparar-age-y-seguridad-social/',
		cta: 'Ver pack conjunto',
		highlight: true,
	},
];

const method = [
	{
		title: 'Clases en directo',
		text: 'Explicaciones online, grabaciones y resolución de dudas para avanzar con estructura.',
	},
	{
		title: 'Material actualizado',
		text: 'Temario, test, esquemas y simulacros ajustados al programa de AGE y Seguridad Social.',
	},
	{
		title: 'Seguimiento cercano',
		text: 'Grupos reducidos y planificación realista según tu punto de partida y disponibilidad.',
	},
];

const blogLinks = [
	{
		title: 'Cómo elegir preparador de oposiciones',
		kicker: 'Preparación',
		href: '/blog/como-elegir-preparadora-oposiciones-age-seguridad-social/',
	},
	{
		title: 'AGE o Seguridad Social: qué preparar',
		kicker: 'Comparativa',
		href: '/blog/age-vs-seguridad-social/',
	},
	{
		title: 'Supuesto práctico de Seguridad Social',
		kicker: 'Seguridad Social',
		href: '/blog/supuesto-practico-administrativo-seguridad-social/',
	},
];

const faqItems = [
	{
		question: '¿Puedo preparar AGE y Seguridad Social a la vez?',
		answer: 'Sí. Una parte importante del temario es común, por eso puede ser eficiente preparar ambas oposiciones con una planificación conjunta.',
	},
	{
		question: '¿Las clases son en directo o grabadas?',
		answer: 'Las clases son en directo por videoconferencia y quedan grabadas para que puedas repasarlas si no puedes asistir o quieres reforzar un tema.',
	},
	{
		question: '¿Cuánto tiempo necesito dedicar por semana?',
		answer: 'Depende de tu punto de partida y de la fecha objetivo, pero lo habitual es trabajar con una planificación semanal realista y sostenida.',
	},
	{
		question: '¿Qué modalidad me conviene?',
		answer: 'Puedes elegir mensual, curso completo, módulos o preparación conjunta. Si tienes dudas, lo más razonable es consultar tu caso antes de matricularte.',
	},
];

const schemaJson = JSON.stringify(withFAQSchema(createHomeSchema(), faqItems));
---

<BaseLayout
	title="Preparadora de Oposiciones AGE y Seguridad Social Online | MC Oposiciones"
	description="Preparadora online de oposiciones AGE y Seguridad Social C1 con Mª Carmen. Clases en directo, grupos reducidos y seguimiento real."
	canonicalUrl="https://mcoposiciones.com/"
	ogType="website"
	schemaJson={schemaJson}
>
	<main class="overflow-x-hidden pt-20">
		<section class="px-4 py-16 sm:px-6 lg:px-8 lg:py-28">
			<div class="mx-auto max-w-7xl">
				<div class="grid gap-16 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
					<div class="max-w-3xl">
						<p class="text-sm font-extrabold uppercase tracking-[0.2em] text-secondary/90">Preparación online AGE y Seguridad Social</p>
						<h1 class="mt-6 text-4xl font-extrabold leading-[1.1] text-primary md:text-6xl lg:text-7xl">
							Preparadora online de oposiciones AGE y Seguridad Social C1
						</h1>
						<p class="mt-8 text-lg leading-relaxed text-text-muted/90 md:text-xl lg:max-w-2xl">
							Prepara las oposiciones de Administrativo del Estado (AGE C1) y Administrativo de la Seguridad Social con Mª Carmen, preparadora especializada. Clases en directo, grupos reducidos y seguimiento real.
						</p>
						<div class="mt-10 flex flex-col gap-4 sm:flex-row">
							<a href="/cursos-precios/" class="inline-flex justify-center rounded-xl bg-secondary px-8 py-4.5 font-bold text-white no-underline shadow-button transition-all duration-300 hover:bg-primary hover:scale-[1.02] active:scale-[0.98]">
								Ver cursos y precios
							</a>
							<a href="/contacto/" class="inline-flex justify-center rounded-xl border border-secondary/30 px-8 py-4.5 font-bold text-secondary no-underline transition-all duration-300 hover:bg-secondary/5 hover:border-secondary hover:scale-[1.02] active:scale-[0.98]">
								Consultar mi caso
							</a>
						</div>
						<div class="mt-12 flex flex-wrap items-center gap-x-10 gap-y-6 border-t border-primary/10 pt-8">
							<div class="flex items-center gap-3.5">
								<div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-secondary/5 text-secondary">
									<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"/><path d="M8 7h6"/><path d="M8 11h8"/></svg>
								</div>
								<div class="flex flex-col justify-center">
									<p class="mb-0 text-[13px] font-bold leading-none text-primary">Doble Oportunidad</p>
									<p class="mb-0 mt-1.5 text-xs leading-none text-text-muted">AGE + Seguridad Social</p>
								</div>
							</div>
							<div class="flex items-center gap-3.5">
								<div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-secondary/5 text-secondary">
									<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m16 13 5.223 3.482a.5.5 0 0 0 .777-.416V7.934a.5.5 0 0 0-.777-.416L16 11"/><rect width="14" height="12" x="2" y="6" rx="2"/></svg>
								</div>
								<div class="flex flex-col justify-center">
									<p class="mb-0 text-[13px] font-bold leading-none text-primary">Clases en Directo</p>
									<p class="mb-0 mt-1.5 text-xs leading-none text-text-muted">Interacción real online</p>
								</div>
							</div>
							<div class="flex items-center gap-3.5">
								<div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-secondary/5 text-secondary">
									<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
								</div>
								<div class="flex flex-col justify-center">
									<p class="mb-0 text-[13px] font-bold leading-none text-primary">Calidad 5.0</p>
									<p class="mb-0 mt-1.5 text-xs leading-none text-text-muted">Reseñas en Google</p>
								</div>
							</div>
						</div>
					</div>
					<div class="lg:pl-8">
						<div class="relative">
							<div class="relative overflow-hidden rounded-2xl border border-primary/5 bg-white shadow-premium">
								<Image src={mariaCarmenImage} alt="Mª Carmen, preparadora de oposiciones AGE y Seguridad Social" width={600} height={600} loading="eager" fetchpriority="high" class="aspect-[4/3] h-full w-full object-cover transition-transform duration-700 hover:scale-105 lg:aspect-square" />
							</div>
							
							<!-- Nuevo bloque de disponibilidad refinado -->
							<div class="absolute -bottom-6 -right-6 hidden max-w-[250px] rounded-xl border border-primary/10 bg-white p-5 shadow-premium sm:block">
								<div class="flex items-center gap-2.5">
									<span class="relative flex h-2 w-2">
										<span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-secondary opacity-75"></span>
										<span class="relative inline-flex h-2 w-2 rounded-full bg-secondary"></span>
									</span>
									<p class="mb-0 text-[10px] font-bold uppercase tracking-[0.1em] leading-none text-secondary">Disponibilidad 2026</p>
								</div>
								<p class="mb-0 mt-3 text-[14px] font-semibold leading-tight text-primary">Plazas limitadas para garantizar seguimiento personal</p>
							</div>
						</div>
						<!-- Mobile version of the availability block -->
						<div class="mt-8 rounded-xl border border-primary/10 bg-white p-5 shadow-sm sm:hidden">
							<div class="flex items-center gap-2.5">
								<span class="relative flex h-2 w-2">
									<span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-secondary opacity-75"></span>
									<span class="relative inline-flex h-2 w-2 rounded-full bg-secondary"></span>
								</span>
								<p class="mb-0 text-[10px] font-bold uppercase tracking-[0.1em] leading-none text-secondary">Disponibilidad 2026</p>
							</div>
							<p class="mb-0 mt-2 text-[14px] font-semibold leading-tight text-primary">Plazas limitadas para garantizar seguimiento personal</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="bg-white/50 px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="mb-16 max-w-3xl">
					<h2 class="text-3xl font-extrabold tracking-tight text-primary md:text-5xl">Elige tu oposición</h2>
					<p class="mt-5 text-lg leading-relaxed text-text-muted/90">Accede a la información detallada sobre convocatorias, exámenes y modalidades de cada especialidad.</p>
				</div>
				<div class="grid gap-6 lg:grid-cols-3 lg:items-stretch">
					{routes.map((route) => (
						<PreparationRouteCard {...route} />
					))}
				</div>
			</div>
		</section>

		<section class="px-4 py-20 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
					<div>
						<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Un método pensado para estudiar con orden</h2>
						<p class="mt-6 text-lg leading-relaxed text-text-muted">
							Preparar una oposición no es acumular PDFs. Es entender el temario, practicar de forma constante y saber dónde poner el esfuerzo cada semana.
						</p>
						<a href="/preparadora-oposiciones/" data-astro-reload class="mt-8 inline-flex rounded-xl bg-secondary px-6 py-3 font-bold text-white no-underline transition-colors hover:bg-primary">
							Conoce a Mª Carmen
						</a>
					</div>
					<div class="grid gap-4">
						{method.map((item) => (
							<article class="rounded-2xl border border-primary/10 bg-white p-6">
								<h3 class="text-xl font-extrabold text-primary">{item.title}</h3>
								<p class="mt-3 leading-relaxed text-text-muted">{item.text}</p>
							</article>
						))}
					</div>
				</div>
			</div>
		</section>

		<section id="opiniones" class="bg-white/50 px-4 py-20 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="mb-12 max-w-3xl">
					<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Opiniones de alumnos</h2>
					<p class="mt-4 text-lg leading-relaxed text-text-muted">La prueba social debe verse pronto y sin adornos innecesarios. Estas reseñas están conectadas con Google.</p>
				</div>
				<div class="mx-auto max-w-[980px]">
					<TestimonialWidget />
				</div>
			</div>
		</section>

		<section class="px-4 py-20 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="mb-12 flex flex-col justify-between gap-6 md:flex-row md:items-end">
					<div class="max-w-3xl">
						<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Guías para decidir mejor</h2>
						<p class="mt-4 text-lg leading-relaxed text-text-muted">Recursos útiles para elegir oposición, comparar opciones y entender qué mirar antes de empezar.</p>
					</div>
					<a href="/blog/" class="inline-flex rounded-xl border border-secondary px-5 py-3 font-bold text-secondary no-underline transition-colors hover:bg-secondary hover:text-white">Ir al blog</a>
				</div>
				<div class="grid gap-5 md:grid-cols-3">
					{blogLinks.map((post) => (
						<a href={post.href} class="rounded-2xl border border-primary/10 bg-white p-6 no-underline transition-colors hover:border-secondary/40">
							<p class="text-xs font-bold uppercase tracking-widest text-secondary">{post.kicker}</p>
							<h3 class="mt-4 text-xl font-extrabold text-primary">{post.title}</h3>
						</a>
					))}
				</div>

				<div class="mx-auto mt-16 max-w-4xl border-t border-primary/10 pt-16">
					<h2 class="mb-10 text-center text-3xl font-extrabold text-primary md:text-4xl">Preguntas frecuentes</h2>
					<FAQAccordion items={faqItems} />
				</div>

				<div class="mx-auto mt-16 max-w-5xl">
					<CTABanner
						title="¿Empezamos a preparar tu plaza?"
						subtitle="Escríbeme sin compromiso y vemos qué camino encaja mejor con tu situación."
						ctaText="Contactar ahora"
						ctaHref="/contacto/"
						variant="primary"
					/>
				</div>
			</div>
		</section>
	</main>
</BaseLayout>
