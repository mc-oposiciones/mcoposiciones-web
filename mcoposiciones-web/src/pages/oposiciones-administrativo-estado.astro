---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTABanner from '../components/CTABanner.astro';
import InfoStepsCard from '../components/InfoStepsCard.astro';
import { createCoursePageSchema, withFAQSchema } from '../lib/schema';

const examFacts = [
	'2.512 plazas totales',
	'Bachillerato requerido',
	'Examen tipo test único',
	'Incluye ofimática M365',
];

const preparationBlocks = [
	{
		title: 'Temario legislativo',
		text: 'Bloques comunes, organización administrativa, derecho administrativo y materias propias del programa oficial.',
	},
	{
		title: 'Ofimática desde cero',
		text: 'Word, Excel y Access se trabajan con enfoque práctico para llegar al examen sin depender de conocimientos previos.',
	},
	{
		title: 'Test y simulacros',
		text: 'Entrenamiento constante de preguntas, tiempos y supuestos para consolidar técnica de examen.',
	},
];

const examStructure = [
	{
		title: 'Test general y ofimática',
		text: '70 preguntas que combinan normativa, organización administrativa y herramientas de Microsoft 365.',
	},
	{
		title: 'Supuesto práctico',
		text: '20 preguntas aplicadas sobre los bloques del programa para medir comprensión y criterio de examen.',
	},
	{
		title: 'Gestión del tiempo',
		text: '100 minutos para resolver ambas partes con seguridad, estrategia de descarte y control de dudas.',
	},
];

const faqItems = [
	{ question: '¿Cuánto tiempo se tarda en preparar el AGE?', answer: 'Entre 8 y 14 meses según la dedicación semanal. Trabajando a jornada completa, con 15 horas semanales, la preparación media es de 12 meses.' },
	{ question: '¿Necesito saber informática para presentarme?', answer: 'No necesitas saber de antemano. La parte de ofimática (Word, Excel, Access) se trabaja desde cero durante la preparación. Muchos alumnos la aprenden durante el curso.' },
	{ question: '¿Cuándo es el examen de AGE 2026?', answer: 'La convocatoria se publica en el BOE. Puedes ver las últimas novedades en nuestro blog.' },
	{ question: '¿Se puede preparar AGE y Seguridad Social a la vez?', answer: 'Sí. Una parte importante del temario es común, por eso puede tener sentido preparar ambas si quieres ampliar opciones sin duplicar todo el estudio.' },
];

const schemaJson = JSON.stringify(withFAQSchema(createCoursePageSchema({
	url: 'https://mcoposiciones.com/oposiciones-administrativo-estado/',
	pageName: 'Preparación oposiciones Administrativo del Estado AGE C1',
	pageDescription: 'Preparación online para las oposiciones de Administrativo del Estado AGE C1 con clases en directo, temario actualizado, test, simulacros y ofimática.',
	courseName: 'Preparación Oposiciones Administrativo del Estado AGE C1',
	courseDescription: 'Preparación online en directo para las oposiciones de Administrativo del Estado (AGE C1) 2026. Clases en directo, 2.512 plazas convocadas, temario actualizado con ofimática incluida.',
}), faqItems));
---

<BaseLayout
	title="Preparadora Oposiciones Administrativo del Estado AGE C1 2026 | MC Oposiciones"
	description="Prepara AGE C1 2026 con Mª Carmen. Clases online en directo, 2.512 plazas, temario actualizado con ofimática y grupos reducidos."
	canonicalUrl="https://mcoposiciones.com/oposiciones-administrativo-estado/"
	schemaJson={schemaJson}
>
	<main class="overflow-x-hidden pt-24">
		<section class="px-4 py-16 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Oposiciones AGE C1', href: '' }]} />
				<header class="mt-12 max-w-4xl">
					<p class="text-sm font-bold uppercase tracking-widest text-secondary">Administración General del Estado</p>
					<h1 class="mt-4 text-4xl font-extrabold leading-tight text-primary md:text-6xl">Administrativo del Estado <span class="text-secondary">(AGE C1)</span></h1>
					<p class="mt-6 text-lg leading-relaxed text-text-muted md:text-xl">
						Preparación online integral para una de las oposiciones con más plazas y recorrido dentro de la Administración Pública.
					</p>
					<div class="mt-8 flex flex-col gap-3 sm:flex-row">
						<a href="/cursos-precios/#age" class="inline-flex justify-center rounded-xl bg-secondary px-6 py-3 font-bold text-white no-underline transition-colors hover:bg-primary">
							Ver precios de AGE
						</a>
						<a href="/preparadora-age/" class="inline-flex justify-center rounded-xl border border-secondary px-6 py-3 font-bold text-secondary no-underline transition-colors hover:bg-secondary hover:text-white">
							Preparadora especializada en AGE
						</a>
					</div>
				</header>
			</div>
		</section>

		<section class="bg-white/50 px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="grid gap-12 lg:grid-cols-2 lg:items-center">
					<div>
						<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Convocatoria AGE 2026</h2>
						<p class="mt-6 text-lg leading-relaxed text-text-muted">
							Trabajar en la Administración General del Estado ofrece estabilidad, sueldo competitivo y posibilidad de destino en distintos organismos de España.
						</p>
						<div class="mt-10 grid gap-4 sm:grid-cols-2">
							{examFacts.map((item) => (
								<div class="flex items-center gap-3 rounded-xl border border-primary/5 bg-white p-4 font-bold text-primary shadow-sm hover:shadow-premium transition-all duration-300">
									<span class="h-2.5 w-2.5 shrink-0 rounded-full bg-secondary"></span>
									<span class="text-sm tracking-tight">{item}</span>
								</div>
							))}
						</div>
					</div>
					<InfoStepsCard title="Detalles técnicos del examen" eyebrow="Estructura AGE" items={examStructure} />
				</div>
			</div>
		</section>

		<section class="px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="mb-12 max-w-3xl">
					<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Cómo se prepara AGE en MC Oposiciones</h2>
					<p class="mt-4 text-text-muted">Esta página explica la oposición y te da una referencia rápida de precio. El detalle completo de modalidades está centralizado en la página de precios.</p>
				</div>
				<div class="grid gap-5 md:grid-cols-3">
					{preparationBlocks.map((block) => (
						<article class="rounded-2xl border border-primary/10 bg-white p-6">
							<h3 class="text-xl font-extrabold text-primary">{block.title}</h3>
							<p class="mt-4 leading-relaxed text-text-muted">{block.text}</p>
						</article>
					))}
				</div>
				<div class="mt-10 rounded-2xl border border-secondary/20 bg-white p-6 shadow-sm md:flex md:items-center md:justify-between md:gap-8">
					<div>
						<p class="text-xs font-extrabold uppercase tracking-[0.18em] text-secondary">Modalidades AGE C1</p>
						<h3 class="mt-2 text-2xl font-extrabold text-primary">Desde 100€/mes o 475€ el curso completo</h3>
						<p class="mt-3 text-text-muted">
							También puedes contratar solo la parte general o solo la parte específica si ya tienes una base previa.
						</p>
					</div>
					<div class="mt-6 w-full md:mt-0 md:w-[22rem]">
						<div class="grid grid-cols-2 divide-x divide-primary/10 border-y border-primary/8 py-4">
							<div class="pr-5 text-center">
								<p class="m-0 text-3xl font-black leading-none text-primary">100€</p>
								<p class="m-0 mt-2 text-[11px] font-extrabold uppercase tracking-widest text-text-muted">mensual</p>
							</div>
							<div class="pl-5 text-center">
								<p class="m-0 text-3xl font-black leading-none text-primary">475€</p>
								<p class="m-0 mt-2 text-[11px] font-extrabold uppercase tracking-widest text-text-muted">curso completo</p>
							</div>
						</div>
						<a href="/cursos-precios/#age" class="mt-4 inline-flex w-full items-center justify-center rounded-xl bg-secondary px-5 py-3 text-sm font-bold text-white no-underline transition-colors hover:bg-primary">
							Ver detalle
						</a>
					</div>
				</div>
				<div class="mt-10 rounded-2xl border border-accent/30 bg-accent/10 p-6 md:flex md:items-center md:justify-between md:gap-8">
					<div>
						<h3 class="text-2xl font-extrabold text-primary">¿AGE o AGE + Seguridad Social?</h3>
						<p class="mt-3 text-text-muted">Si quieres aprovechar el temario común, revisa el pack conjunto antes de elegir modalidad.</p>
					</div>
					<a href="/preparar-age-y-seguridad-social/" class="mt-6 inline-flex rounded-xl bg-accent px-6 py-3 font-bold text-primary no-underline transition-colors hover:bg-primary hover:text-white md:mt-0">
						Ver preparación conjunta
					</a>
				</div>
			</div>
		</section>

		<section class="bg-white/50 px-4 py-20 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-4xl">
				<h2 class="mb-10 text-center text-3xl font-extrabold text-primary md:text-4xl">Dudas comunes sobre AGE</h2>
				<FAQAccordion items={faqItems} />
			</div>

			<div class="mx-auto mt-16 max-w-5xl">
				<CTABanner
					title="¿Quieres preparar Administrativo del Estado?"
					subtitle="Escríbeme y te cuento qué modalidad encaja mejor con tu situación actual."
					ctaText="Información sobre AGE"
					ctaHref="/contacto/"
					variant="primary"
				/>
			</div>
		</section>
	</main>
</BaseLayout>
