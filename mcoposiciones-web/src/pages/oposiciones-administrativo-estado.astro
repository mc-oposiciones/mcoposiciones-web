---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CourseCard from '../components/CourseCard.astro';
import TestimonialWidget from '../components/TestimonialWidget.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTABanner from '../components/CTABanner.astro';

const schemaJson = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'Course',
	name: 'Preparación Oposiciones Administrativo del Estado AGE C1 2026',
	description: 'Preparación online en directo para las oposiciones de Administrativo del Estado (Grupo C1). Temario completo en 6 bloques, test, simulacros y supuesto práctico.',
	provider: { '@type': 'Organization', name: 'MC Oposiciones', url: 'https://mcoposiciones.com' },
	offers: {
		'@type': 'Offer',
		price: '100',
		priceCurrency: 'EUR',
		availability: 'https://schema.org/InStock',
		priceSpecification: { '@type': 'UnitPriceSpecification', price: '100', priceCurrency: 'EUR', unitText: 'MONTH' },
	},
	educationalLevel: 'C1',
	inLanguage: 'es',
});

const faqItems = [
	{ question: '¿Cuánto tiempo se tarda en preparar el AGE?', answer: 'Entre 8 y 14 meses según la dedicación semanal. Trabajando a jornada completa, con 15 horas semanales, la preparación media es de 12 meses.' },
	{ question: '¿Necesito saber informática para presentarme?', answer: 'No necesitas saber de antemano. La parte de ofimática (Word, Excel, Access) se trabaja desde cero durante la preparación. Muchos alumnos la aprenden durante el curso.' },
	{ question: '¿Cuándo es el examen de AGE 2026?', answer: 'La convocatoria se publica en el BOE. Puedes ver las últimas novedades en nuestro blog.' },
	{ question: '¿Se puede preparar AGE y Seguridad Social a la vez?', answer: 'Sí, es la mejor opción. El 75% del temario es idéntico. Descubre el Pack Doble en /preparar-age-y-seguridad-social/' },
];
---

<BaseLayout
	title="Preparadora Oposiciones Administrativo del Estado AGE C1 2026 | MC Oposiciones"
	description="Prepara con Mª Carmen las oposiciones de Administrativo del Estado (AGE C1) 2026. Clases online en directo, 2.512 plazas convocadas, temario actualizado con informática incluida. Sin compromiso de permanencia."
	canonicalUrl="https://mcoposiciones.com/oposiciones-administrativo-estado/"
	schemaJson={schemaJson}
>
	<main class="overflow-x-hidden pt-24">
		<section class="px-4 py-16 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Oposiciones AGE C1', href: '' }]} />
				<header class="mt-12 max-w-4xl">
					<h1 class="text-4xl font-extrabold text-primary md:text-6xl leading-tight">Administrativo del Estado <span class="text-secondary">(AGE C1)</span></h1>
					<p class="mt-6 text-lg leading-relaxed text-text-muted md:text-xl">
						Preparación online integral 2026. Una de las oposiciones con más plazas y oportunidades de toda la Administración Pública.
					</p>
					<a href="/preparadora-age/" class="mt-6 inline-flex font-bold text-secondary no-underline hover:text-accent">
						Ver preparadora especializada en AGE
					</a>
				</header>
			</div>
		</section>

		<section class="bg-white px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="grid gap-12 lg:grid-cols-2 lg:items-center">
					<div>
						<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Convocatoria AGE 2026</h2>
						<p class="mt-6 text-lg leading-relaxed text-text-muted">
							Trabajar en la Administración General del Estado te ofrece estabilidad, un sueldo competitivo (1.500€ - 1.900€ netos) y la posibilidad de elegir destino en toda España.
						</p>
						<div class="mt-10 grid gap-4 sm:grid-cols-2">
							{[
								'2.512 plazas totales',
								'Bachillerato requerido',
								'Examen tipo test único',
								'Incluye ofimática M365'
							].map((item) => (
								<div class="rounded-xl border border-primary/5 bg-bg-light/30 p-4 font-bold text-primary">
									{item}
								</div>
							))}
						</div>
					</div>
					<div class="rounded-[2.5rem] bg-bg-dark/40 p-8 md:p-12">
						<h3 class="text-xl font-bold text-primary">Detalles técnicos del examen</h3>
						<ul class="mt-6 space-y-4">
							<li class="flex gap-4">
								<span class="font-black text-secondary">01</span>
								<p class="text-sm text-text-main"><strong>Parte Test:</strong> 70 preguntas (40 temario + 30 ofimática).</p>
							</li>
							<li class="flex gap-4">
								<span class="font-black text-secondary">02</span>
								<p class="text-sm text-text-main"><strong>Parte Práctica:</strong> Supuesto de 20 preguntas sobre bloques II-V.</p>
							</li>
							<li class="flex gap-4">
								<span class="font-black text-secondary">03</span>
								<p class="text-sm text-text-main"><strong>Tiempo:</strong> 100 minutos para realizar ambas partes del examen.</p>
							</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<section class="px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="mb-16 text-center">
					<h2 class="text-3xl font-extrabold text-primary md:text-5xl">Opciones de preparación</h2>
					<p class="mt-4 text-text-muted">Elige el plan que mejor se adapte a tus necesidades de estudio.</p>
				</div>
				<div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
					<CourseCard title="Mensual" description="Clases en directo y acceso completo mes a mes. Sin permanencia." price="100€" priceType="/mes" href="/cursos-precios/" features={['Directo + Grabaciones', 'Todo el material incluido', 'Resolución de dudas']} />
					<CourseCard title="Completo" description="Preparación integral hasta el día del examen. El plan más ahorrador." price="475€" priceType="pago único" href="/cursos-precios/" features={['Acceso ilimitado', 'Simulacros examen real', 'Soporte prioritario']} />
					<CourseCard title="Parte General" description="Solo bloques I al V del temario. Ideal si ya dominas la ofimática." price="250€" priceType="pago único" href="/cursos-precios/" features={['Temario legislativo', 'Test específicos', 'Clases grabadas']} />
				</div>
			</div>
		</section>

		<section class="bg-white px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-4xl">
				<h2 class="mb-12 text-center text-3xl font-extrabold text-primary md:text-4xl">Dudas comunes sobre AGE</h2>
				<FAQAccordion items={faqItems} />
			</div>
		</section>

		<section class="px-4 pb-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-5xl">
				<CTABanner 
					title="¿Quieres asegurar tu plaza en el Estado?" 
					subtitle="Escríbeme y te cuento las fechas de inicio de los nuevos grupos de preparación." 
					ctaText="Información sobre AGE" 
					ctaHref="/contacto/" 
					variant="primary"
				/>
			</div>
		</section>
	</main>
</BaseLayout>
