---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTABanner from '../components/CTABanner.astro';
import InfoStepsCard from '../components/InfoStepsCard.astro';
import { createCoursePageSchema } from '../lib/schema';

const schemaJson = JSON.stringify(createCoursePageSchema({
	url: 'https://mcoposiciones.com/oposiciones-seguridad-social/',
	pageName: 'Preparacion oposiciones Administrativo de la Seguridad Social C1',
	pageDescription: 'Preparacion online para Administrativo de la Seguridad Social C1 con temario especifico, test, supuesto practico y clases en directo.',
	courseName: 'Preparacion oposiciones Administrativo de la Seguridad Social C1',
	courseDescription: 'Preparacion online en directo para Administrativo de la Seguridad Social C1. Incluye temario especifico, test, simulacros y supuesto practico.',
}));

const examFacts = [
	'1.456 plazas libres',
	'Examen: 28 junio 2026',
	'Sin méritos: solo nota',
	'Sin prueba de ofimática',
];

const preparationBlocks = [
	{
		title: 'Temario específico',
		text: 'Legislación propia de Seguridad Social explicada con estructura, ejemplos y enfoque de examen.',
	},
	{
		title: 'Supuesto práctico',
		text: 'Entrenamiento progresivo de casos para entender la lógica del ejercicio y no limitarse a memorizar.',
	},
	{
		title: 'Plan para aprovechar AGE',
		text: 'Si ya vienes de Administrativo del Estado, se priorizan las diferencias reales para no duplicar estudio.',
	},
];

const examStructure = [
	{
		title: 'Test general y específico',
		text: '70 preguntas sobre la parte común administrativa y el bloque propio de Seguridad Social.',
	},
	{
		title: 'Supuesto práctico',
		text: '15 preguntas sobre casos de Seguridad Social para comprobar aplicación normativa y razonamiento.',
	},
	{
		title: 'Examen en 120 minutos',
		text: 'Una única sesión para resolver ambas partes con lectura precisa, control de tiempos y método.',
	},
];

const faqItems = [
	{ question: '¿Cuándo es el examen de Administrativo de Seguridad Social 2026?', answer: 'El examen está fijado para el 28 de junio de 2026. Ambas partes del ejercicio se realizan el mismo día.' },
	{ question: '¿Es difícil el supuesto práctico de Seguridad Social?', answer: 'Es la parte que más preocupa a los opositores. En MC Oposiciones trabajamos el supuesto práctico desde el primer mes para que llegues al examen con confianza total.' },
	{ question: '¿Se puede preparar Seguridad Social a la vez que AGE?', answer: 'Sí. Es una opción muy interesante porque una parte importante del temario se aprovecha entre ambas oposiciones.' },
	{ question: '¿Qué diferencia hay entre el temario de AGE y el de SS?', answer: 'El temario general es muy parecido. La diferencia principal es que AGE incluye ofimática y Seguridad Social tiene temario específico y supuesto práctico propio.' },
];
---

<BaseLayout
	title="Preparadora Oposiciones Administrativo Seguridad Social C1 2026 | MC Oposiciones"
	description="Prepara con Mª Carmen las oposiciones de Administrativo de la Seguridad Social (C1) 2026. 1.456 plazas, sin ofimática, examen 28 junio 2026. Clases online en directo con temario específico SS actualizado."
	canonicalUrl="https://mcoposiciones.com/oposiciones-seguridad-social/"
	schemaJson={schemaJson}
>
	<main class="overflow-x-hidden pt-24">
		<section class="px-4 py-16 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Oposiciones Seguridad Social C1', href: '' }]} />
				<header class="mt-12 max-w-4xl">
					<p class="text-sm font-bold uppercase tracking-widest text-secondary">Administración de la Seguridad Social</p>
					<h1 class="mt-4 text-4xl font-extrabold leading-tight text-primary md:text-6xl">Administrativo de la <span class="text-secondary">Seguridad Social</span></h1>
					<p class="mt-6 text-lg leading-relaxed text-text-muted md:text-xl">
						Preparación especializada para una oposición C1 sin ofimática, con temario propio y una fecha de examen ya definida.
					</p>
					<div class="mt-8 flex flex-col gap-3 sm:flex-row">
						<a href="/cursos-precios/" class="inline-flex justify-center rounded-xl bg-secondary px-6 py-3 font-bold text-white no-underline transition-colors hover:bg-primary">
							Ver cursos y precios
						</a>
						<a href="/preparadora-seguridad-social/" class="inline-flex justify-center rounded-xl border border-secondary px-6 py-3 font-bold text-secondary no-underline transition-colors hover:bg-secondary hover:text-white">
							Preparadora especializada en SS
						</a>
					</div>
				</header>
			</div>
		</section>

		<section class="bg-white/50 px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="grid gap-12 lg:grid-cols-2 lg:items-center">
					<div>
						<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Convocatoria Seguridad Social 2026</h2>
						<p class="mt-6 text-lg leading-relaxed text-text-muted">
							Trabajar en la Seguridad Social significa gestionar prestaciones y procedimientos clave en organismos como INSS o Tesorería.
						</p>
						<div class="mt-10 grid gap-4 sm:grid-cols-2">
							{examFacts.map((item, index) => (
								<div class={`flex items-center gap-3 rounded-xl border border-primary/5 bg-white p-4 font-bold shadow-sm hover:shadow-premium transition-all duration-300 ${index === 1 ? 'text-secondary' : 'text-primary'}`}>
									<span class={`h-2.5 w-2.5 shrink-0 rounded-full ${index === 1 ? 'bg-accent animate-pulse' : 'bg-secondary'}`}></span>
									<span class="text-sm tracking-tight">{item}</span>
								</div>
							))}
						</div>
					</div>
					<InfoStepsCard title="Estructura del examen" eyebrow="Seguridad Social C1" items={examStructure} />
				</div>
			</div>
		</section>

		<section class="px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="mb-12 max-w-3xl">
					<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Cómo se prepara Seguridad Social</h2>
					<p class="mt-4 text-text-muted">Aquí el foco está en entender la oposición. Las modalidades económicas se consultan de forma centralizada en la página de precios.</p>
				</div>
				<div class="grid gap-5 md:grid-cols-3">
					{preparationBlocks.map((block) => (
						<article class="rounded-2xl border border-primary/10 bg-white p-6">
							<h3 class="text-xl font-extrabold text-primary">{block.title}</h3>
							<p class="mt-4 leading-relaxed text-text-muted">{block.text}</p>
						</article>
					))}
				</div>
				<div class="mt-10 rounded-2xl border border-accent/30 bg-accent/10 p-6 md:flex md:items-center md:justify-between md:gap-8">
					<div>
						<h3 class="text-2xl font-extrabold text-primary">¿Vienes de preparar AGE?</h3>
						<p class="mt-3 text-text-muted">Puede ser más eficiente completar solo la parte específica de Seguridad Social o plantear una preparación conjunta.</p>
					</div>
					<a href="/cursos-precios/" class="mt-6 inline-flex rounded-xl bg-accent px-6 py-3 font-bold text-primary no-underline transition-colors hover:bg-primary hover:text-white md:mt-0">
						Ver modalidades
					</a>
				</div>
			</div>
		</section>

		<section class="bg-white/50 px-4 py-20 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-4xl">
				<h2 class="mb-10 text-center text-3xl font-extrabold text-primary md:text-4xl">Dudas sobre Seguridad Social</h2>
				<FAQAccordion items={faqItems} />
			</div>

			<div class="mx-auto mt-16 max-w-5xl">
				<CTABanner
					title="¿Preparamos tu plaza en la Seguridad Social?"
					subtitle="Escríbeme y vemos si te conviene curso completo, parte específica o preparación combinada con AGE."
					ctaText="Quiero información"
					ctaHref="/contacto/"
					variant="primary"
				/>
			</div>
		</section>
	</main>
</BaseLayout>
