---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import TestimonialWidget from '../components/TestimonialWidget.astro';
import { createPreparadoraLandingSchema } from '../lib/schema';

const canonicalUrl = 'https://mcoposiciones.com/preparadora-age/';
const schemaJson = JSON.stringify(createPreparadoraLandingSchema({
	url: canonicalUrl,
	name: 'Preparadora AGE online para Administrativo del Estado C1',
	description: 'Preparacion online con Maria Carmen para las oposiciones de Administrativo del Estado AGE C1. Clases en directo, grupos reducidos, temario actualizado y seguimiento cercano.',
	courseName: 'Preparacion oposiciones Administrativo del Estado AGE C1',
}));

const faqItems = [
	{
		question: 'Que incluye la preparacion AGE con Maria Carmen?',
		answer: 'Incluye clases online en directo, grabaciones, temario actualizado, test por temas, simulacros, ofimatica y acompanamiento durante la preparacion.',
	},
	{
		question: 'La preparacion sirve si empiezo desde cero?',
		answer: 'Si. El metodo esta pensado para avanzar desde la base, entendiendo la ley, entrenando test y trabajando la ofimatica de forma progresiva.',
	},
	{
		question: 'Es mejor una preparadora o una academia grande?',
		answer: 'Depende de lo que necesites. Si buscas seguimiento cercano, grupos reducidos y una estrategia clara, trabajar con una preparadora especializada suele ser mas eficiente que entrar en un grupo masificado.',
	},
	{
		question: 'Puedo preparar AGE y Seguridad Social a la vez?',
		answer: 'Si. AGE y Seguridad Social comparten gran parte del temario. Por eso existe un pack especifico para preparar ambas oposiciones con una misma planificacion.',
	},
];
---

<BaseLayout
	title="Preparadora AGE Online | Administrativo del Estado C1 | MC Oposiciones"
	description="Preparadora AGE online para Administrativo del Estado C1. Clases en directo con Maria Carmen, grupos reducidos, temario actualizado, test, ofimatica y seguimiento cercano."
	canonicalUrl={canonicalUrl}
	schemaJson={schemaJson}
>
	<main class="overflow-x-hidden pt-24">
		<section class="px-4 py-16 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Preparadora AGE', href: '' }]} />
				<div class="mt-12 grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
					<header>
						<p class="text-sm font-extrabold uppercase tracking-widest text-secondary">Preparacion online AGE C1</p>
						<h1 class="mt-4 text-4xl font-extrabold leading-tight text-primary md:text-6xl">
							Preparadora AGE para Administrativo del Estado
						</h1>
						<p class="mt-6 max-w-3xl text-lg leading-relaxed text-text-muted md:text-xl">
							Una landing pensada para quien ya busca preparadora, no una ficha general de la oposicion. Aqui el foco esta en el acompanamiento, el metodo y la forma de trabajar AGE C1 con Maria Carmen.
						</p>
						<div class="mt-10 flex flex-col gap-4 sm:flex-row">
							<a href="/contacto/" class="rounded-xl bg-secondary px-8 py-4 text-center font-bold text-white no-underline transition-colors hover:bg-primary">
								Pedir informacion AGE
							</a>
							<a href="/oposiciones-administrativo-estado/" class="rounded-xl border border-secondary px-8 py-4 text-center font-bold text-secondary no-underline transition-colors hover:bg-secondary hover:text-white">
								Ver detalles de la oposicion
							</a>
						</div>
					</header>
					<aside class="rounded-2xl border border-primary/10 bg-white p-8">
						<h2 class="text-2xl font-extrabold text-primary">Para quien es esta preparacion?</h2>
						<ul class="mt-6 space-y-4">
							<li class="flex gap-3"><span class="font-black text-secondary">01</span><span>Quieres preparar AGE C1 con una guia clara y directa.</span></li>
							<li class="flex gap-3"><span class="font-black text-secondary">02</span><span>Necesitas entender el temario, no memorizarlo sin criterio.</span></li>
							<li class="flex gap-3"><span class="font-black text-secondary">03</span><span>Buscas clases en directo, material ordenado y seguimiento real.</span></li>
							<li class="flex gap-3"><span class="font-black text-secondary">04</span><span>Quieres entrenar test, supuesto practico y ofimatica desde el inicio.</span></li>
						</ul>
					</aside>
				</div>
			</div>
		</section>

		<section class="bg-white/50 px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="mb-14 max-w-3xl">
					<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Un metodo centrado en aprobar AGE</h2>
					<p class="mt-6 text-lg leading-relaxed text-text-muted">
						La preparacion combina explicacion juridica, entrenamiento constante y organizacion semanal. El objetivo es que sepas que estudiar, como repasarlo y como enfrentarte al examen.
					</p>
				</div>
				<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
					{[
						{ title: 'Temario explicado', text: 'Clases claras para entender leyes, procedimientos y conceptos clave.' },
						{ title: 'Ofimatica AGE', text: 'Trabajo especifico de Word, Excel y Access orientado al examen.' },
						{ title: 'Test y simulacros', text: 'Entrenamiento progresivo para ganar precision y velocidad.' },
						{ title: 'Seguimiento cercano', text: 'Grupos reducidos y resolucion de dudas durante el proceso.' },
					].map((item) => (
						<article class="rounded-2xl border border-primary/10 bg-bg-light/40 p-6">
							<h3 class="text-xl font-bold text-primary">{item.title}</h3>
							<p class="mt-3 text-sm leading-relaxed text-text-muted">{item.text}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-2 lg:items-start">
				<div>
					<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Preparadora AGE o academia?</h2>
					<p class="mt-6 text-lg leading-relaxed text-text-muted">
						Una academia grande puede darte volumen de material. Una preparadora especializada te ayuda a priorizar, corregir errores de enfoque y mantener una estrategia realista. En oposiciones C1, esa diferencia puede ser decisiva.
					</p>
					<p class="mt-4 text-lg leading-relaxed text-text-muted">
						En MC Oposiciones el enfoque es directo: grupos reducidos, clases utiles, materiales actualizados y preparacion orientada al examen oficial de Administrativo del Estado.
					</p>
				</div>
				<div class="rounded-2xl border border-secondary/20 bg-secondary/10 p-8">
					<h3 class="text-2xl font-extrabold text-primary">Tambien puedes doblar opciones</h3>
					<p class="mt-4 leading-relaxed text-text-main">
						AGE y Seguridad Social comparten gran parte del temario. Si quieres aprovechar mejor el esfuerzo, revisa la preparacion conjunta.
					</p>
					<a href="/preparar-age-y-seguridad-social/" class="mt-6 inline-flex rounded-xl bg-secondary px-5 py-3 font-bold text-white no-underline transition-colors hover:bg-primary">Ver Pack AGE + Seguridad Social</a>
				</div>
			</div>
		</section>

		<section class="bg-white/50 px-4 py-20 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="grid gap-8 rounded-2xl border border-primary/10 bg-bg-light/40 p-8 md:grid-cols-[1fr_auto] md:items-center">
					<div>
						<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Antes de elegir preparadora, revisa la oposicion</h2>
						<p class="mt-4 leading-relaxed text-text-muted">
							La pagina de Administrativo del Estado resume convocatoria, estructura de examen y bloques de preparacion. Esta landing queda enfocada en la eleccion de preparadora.
						</p>
					</div>
					<a href="/oposiciones-administrativo-estado/" class="inline-flex justify-center rounded-xl border border-secondary px-6 py-3 font-bold text-secondary no-underline transition-colors hover:bg-secondary hover:text-white">
						Ver AGE C1
					</a>
				</div>

				<div class="mx-auto mt-16 max-w-6xl border-t border-primary/10 pt-16">
					<div class="mb-12 text-center">
						<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Opiniones de alumnos</h2>
					</div>
					<TestimonialWidget variant="grid" />
				</div>
			</div>
		</section>

		<section class="px-4 py-20 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-4xl">
				<h2 class="mb-10 text-center text-3xl font-extrabold text-primary md:text-4xl">Preguntas frecuentes sobre preparar AGE</h2>
				<FAQAccordion items={faqItems} />
			</div>

			<div class="mx-auto mt-16 max-w-5xl">
				<CTABanner
					title="Quieres preparar AGE con seguimiento cercano?"
					subtitle="Escribeme y vemos si el grupo de Administrativo del Estado encaja con tu punto de partida y disponibilidad."
					ctaText="Pedir informacion"
					ctaHref="/contacto/"
					variant="primary"
				/>
			</div>
		</section>
	</main>
</BaseLayout>
