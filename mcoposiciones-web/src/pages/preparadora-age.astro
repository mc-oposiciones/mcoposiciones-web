---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import TestimonialWidget from '../components/TestimonialWidget.astro';
import { createPreparadoraLandingSchema, withFAQSchema } from '../lib/schema';

const canonicalUrl = 'https://mcoposiciones.com/preparadora-age/';

const faqItems = [
	{
		question: '¿Qué incluye la preparación AGE con Mª Carmen?',
		answer: 'Incluye clases online en directo, grabaciones, temario actualizado, test por temas, simulacros, ofimática y acompañamiento durante la preparación.',
	},
	{
		question: '¿La preparación sirve si empiezo desde cero?',
		answer: 'Sí. El método está pensado para avanzar desde la base, entendiendo la ley, entrenando test y trabajando la ofimática de forma progresiva.',
	},
	{
		question: '¿Es mejor una preparadora o una academia grande?',
		answer: 'Depende de lo que necesites. Si buscas seguimiento cercano, grupos reducidos y una estrategia clara, trabajar con una preparadora especializada suele ser más eficiente que entrar en un grupo masificado.',
	},
	{
		question: '¿Puedo preparar AGE y Seguridad Social a la vez?',
		answer: 'Sí. AGE y Seguridad Social comparten gran parte del temario. Por eso existe un pack específico para preparar ambas oposiciones con una misma planificación.',
	},
];

const schemaJson = JSON.stringify(withFAQSchema(createPreparadoraLandingSchema({
	url: canonicalUrl,
	name: 'Preparadora AGE online para Administrativo del Estado C1',
	description: 'Preparación online con Mª Carmen para las oposiciones de Administrativo del Estado AGE C1. Clases en directo, grupos reducidos, temario actualizado y seguimiento cercano.',
	courseName: 'Preparación oposiciones Administrativo del Estado AGE C1',
}), faqItems));
---

<BaseLayout
	title="Preparadora AGE Online | Administrativo del Estado C1 | MC Oposiciones"
	description="Prepara el AGE C1 con Mª Carmen, preparadora online especializada. Clases en directo, grupos reducidos, ofimática incluida y seguimiento real."
	canonicalUrl={canonicalUrl}
	schemaJson={schemaJson}
>
	<main class="overflow-x-hidden pt-24">
		<section class="px-4 py-16 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Preparadora AGE', href: '' }]} />
				<div class="mt-12 grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
					<header>
						<p class="text-sm font-extrabold uppercase tracking-widest text-secondary">Preparación online AGE C1</p>
						<h1 class="mt-4 text-4xl font-extrabold leading-tight text-primary md:text-6xl">
							Preparadora AGE para Administrativo del Estado
						</h1>
						<p class="mt-6 max-w-3xl text-lg leading-relaxed text-text-muted md:text-xl">
							Prepara Administrativo del Estado C1 con clases online en directo, temario actualizado, ofimática, test y una planificación pensada para avanzar con criterio desde el primer día.
						</p>
						<div class="mt-10 flex flex-col gap-4 sm:flex-row">
							<a href="/contacto/" class="rounded-xl bg-secondary px-8 py-4 text-center font-bold text-white no-underline transition-colors hover:bg-primary">
								Pedir información AGE
							</a>
							<a href="/oposiciones-administrativo-estado/" class="rounded-xl border border-secondary px-8 py-4 text-center font-bold text-secondary no-underline transition-colors hover:bg-secondary hover:text-white">
								Ver detalles de la oposición
							</a>
						</div>
					</header>
					<aside class="rounded-2xl border border-primary/10 bg-white p-8">
						<h2 class="text-2xl font-extrabold text-primary">¿Para quién es esta preparación?</h2>
						<ul class="mt-6 space-y-4">
							<li class="flex gap-3"><span class="font-black text-secondary">01</span><span>Quieres preparar AGE C1 con una guía clara y directa.</span></li>
							<li class="flex gap-3"><span class="font-black text-secondary">02</span><span>Necesitas entender el temario, no memorizarlo sin criterio.</span></li>
							<li class="flex gap-3"><span class="font-black text-secondary">03</span><span>Buscas clases en directo, material ordenado y seguimiento real.</span></li>
							<li class="flex gap-3"><span class="font-black text-secondary">04</span><span>Quieres entrenar test, supuesto práctico y ofimática desde el inicio.</span></li>
						</ul>
					</aside>
				</div>
			</div>
		</section>

		<section class="bg-white/50 px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="mb-14 max-w-3xl">
					<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Un método centrado en aprobar AGE</h2>
					<p class="mt-6 text-lg leading-relaxed text-text-muted">
						La preparación combina explicación jurídica, entrenamiento constante y organización semanal. El objetivo es que sepas qué estudiar, cómo repasarlo y cómo enfrentarte al examen.
					</p>
				</div>
				<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
					{[
						{ title: 'Temario explicado', text: 'Clases claras para entender leyes, procedimientos y conceptos clave.' },
						{ title: 'Ofimática AGE', text: 'Trabajo específico de Word, Excel y Access orientado al examen.' },
						{ title: 'Test y simulacros', text: 'Entrenamiento progresivo para ganar precisión y velocidad.' },
						{ title: 'Seguimiento cercano', text: 'Grupos reducidos y resolución de dudas durante el proceso.' },
					].map((item) => (
						<article class="rounded-2xl border border-primary/10 bg-bg-light/40 p-6">
							<h3 class="text-xl font-bold text-primary">{item.title}</h3>
							<p class="mt-3 text-sm leading-relaxed text-text-muted">{item.text}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-2 lg:items-start">
				<div>
					<h2 class="text-3xl font-extrabold text-primary md:text-4xl">¿Preparación cercana o academia masificada?</h2>
					<p class="mt-6 text-lg leading-relaxed text-text-muted">
						Una oposición C1 no se prepara solo acumulando apuntes. Necesitas saber qué estudiar, cómo repasarlo y cuándo empezar a entrenar el examen. Ese orden marca la diferencia cuando el temario empieza a crecer.
					</p>
					<p class="mt-4 text-lg leading-relaxed text-text-muted">
						En MC Oposiciones el enfoque es directo: grupos reducidos, clases útiles, materiales actualizados y preparación orientada al examen oficial de Administrativo del Estado.
					</p>
				</div>
				<div class="rounded-2xl border border-accent/30 bg-accent/10 p-8">
					<h3 class="text-2xl font-extrabold text-primary">También puedes doblar opciones</h3>
					<p class="mt-4 leading-relaxed text-text-main">
						AGE y Seguridad Social comparten gran parte del temario. Si quieres aprovechar mejor el esfuerzo, revisa la preparación conjunta.
					</p>
					<a href="/preparar-age-y-seguridad-social/" class="mt-6 inline-flex rounded-xl bg-accent px-5 py-3 font-bold text-primary no-underline transition-colors hover:bg-primary hover:text-white">Ver Pack AGE + Seguridad Social</a>
				</div>
			</div>
		</section>

		<section class="bg-white/50 px-4 py-20 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="grid gap-8 rounded-2xl border border-primary/10 bg-bg-light/40 p-8 md:grid-cols-[1fr_auto] md:items-center">
					<div>
						<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Conoce bien la oposición antes de empezar</h2>
						<p class="mt-4 leading-relaxed text-text-muted">
							Si todavía estás valorando si AGE C1 encaja contigo, puedes revisar la estructura del examen, los bloques del temario y las modalidades de preparación antes de decidir tu siguiente paso.
						</p>
					</div>
					<a href="/oposiciones-administrativo-estado/" class="inline-flex justify-center rounded-xl border border-secondary px-6 py-3 font-bold text-secondary no-underline transition-colors hover:bg-secondary hover:text-white">
						Ver AGE C1
					</a>
				</div>

				<div class="mx-auto mt-12 max-w-6xl border-t border-primary/10 pt-12">
					<div class="mb-8 text-center">
						<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Opiniones de alumnos</h2>
					</div>
					<TestimonialWidget variant="grid" />
				</div>
			</div>
		</section>

		<section class="px-4 py-20 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-4xl">
				<h2 class="mb-10 text-center text-3xl font-extrabold text-primary md:text-4xl">Preguntas frecuentes sobre preparar AGE</h2>
				<FAQAccordion items={faqItems} />
			</div>

			<div class="mx-auto mt-16 max-w-5xl">
				<CTABanner
					title="¿Quieres preparar AGE con seguimiento cercano?"
					subtitle="Escríbeme y vemos si el grupo de Administrativo del Estado encaja con tu punto de partida y disponibilidad."
					ctaText="Pedir información"
					ctaHref="/contacto/"
					variant="primary"
				/>
			</div>
		</section>
	</main>
</BaseLayout>
