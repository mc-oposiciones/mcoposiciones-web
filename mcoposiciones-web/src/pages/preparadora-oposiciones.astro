---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import TestimonialWidget from '../components/TestimonialWidget.astro';
import CTABanner from '../components/CTABanner.astro';
import { Image } from 'astro:assets';
import mariaCarmenImage from '../assets/images/maria-carmen.jpg';
import { createPersonSchema } from '../lib/schema';

const schemaJson = JSON.stringify(createPersonSchema());

const trustItems = [
	'Preparación especializada en AGE C1 y Seguridad Social C1',
	'Grupos reducidos y atención directa durante el proceso',
	'Clases online en directo, grabaciones y material actualizado',
];

const methodItems = [
	{
		title: 'Explicar antes de memorizar',
		desc: 'El temario se trabaja con contexto y ejemplos para que puedas contestar con criterio, no solo repetir artículos.',
	},
	{
		title: 'Entrenar el examen desde el principio',
		desc: 'Test, supuestos y repasos se integran en la preparación para llegar con técnica, ritmo y control del tiempo.',
	},
	{
		title: 'Planificar con realismo',
		desc: 'La preparación se adapta al tiempo disponible. El objetivo es sostener el estudio sin perder foco.',
	},
];

const routes = [
	{
		title: 'Administrativo del Estado',
		text: 'AGE C1 con temario legislativo, ofimática y entrenamiento de examen.',
		href: '/oposiciones-administrativo-estado/',
		cta: 'Ver AGE C1',
	},
	{
		title: 'Seguridad Social',
		text: 'Preparación C1 con temario específico y supuesto práctico desde el inicio.',
		href: '/oposiciones-seguridad-social/',
		cta: 'Ver Seguridad Social',
	},
	{
		title: 'AGE + Seguridad Social',
		text: 'Preparación conjunta para aprovechar el temario común y ampliar opciones.',
		href: '/preparar-age-y-seguridad-social/',
		cta: 'Ver pack conjunto',
		highlight: true,
	},
];
---
<BaseLayout
	title="Mª Carmen — Preparadora de Oposiciones AGE y Seguridad Social | MC Oposiciones"
	description="Conoce a Mª Carmen, preparadora especializada en oposiciones de Administrativo del Estado (AGE C1) y Administrativo de la Seguridad Social (C1). Método riguroso, grupos reducidos y acompañamiento real."
	canonicalUrl="https://mcoposiciones.com/preparadora-oposiciones/"
	schemaJson={schemaJson}
>
	<main class="overflow-x-hidden pt-24">
		<section class="px-4 py-16 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Preparadora de oposiciones', href: '' }]} />
				<div class="mt-12 grid gap-12 lg:grid-cols-[380px_1fr] lg:items-center">
					<div class="relative max-w-sm">
						<div class="relative overflow-hidden rounded-2xl border border-primary/10 bg-white">
							<Image src={mariaCarmenImage} alt="Mª Carmen, preparadora de oposiciones" width={600} height={600} loading="eager" fetchpriority="high" class="aspect-square h-full w-full object-cover" />
						</div>
					</div>
					<div>
						<p class="text-sm font-extrabold uppercase tracking-widest text-secondary">Preparadora de oposiciones online</p>
						<h1 class="mt-4 text-4xl font-extrabold leading-tight text-primary md:text-6xl">Hola, soy Mª Carmen</h1>
						<p class="mt-6 max-w-3xl text-lg leading-relaxed text-text-muted md:text-xl">
							Preparo opositores de Administrativo del Estado y Seguridad Social con una metodología cercana, exigente y centrada en el examen. Mi trabajo es ayudarte a estudiar con estructura, resolver dudas y mantener una estrategia realista hasta la convocatoria.
						</p>
						<div class="mt-8 grid gap-3">
							{trustItems.map((item) => (
								<div class="flex gap-3 rounded-xl border border-primary/10 bg-white px-4 py-3 text-sm font-bold text-primary">
									<span class="text-secondary">✓</span>
									<span>{item}</span>
								</div>
							))}
						</div>
						<div class="mt-8 flex flex-col gap-3 sm:flex-row">
							<a href="/contacto/" class="inline-flex justify-center rounded-xl bg-secondary px-6 py-3 font-bold text-white no-underline transition-colors hover:bg-primary">
								Contactar
							</a>
							<a href="/cursos-precios/" class="inline-flex justify-center rounded-xl border border-secondary px-6 py-3 font-bold text-secondary no-underline transition-colors hover:bg-secondary hover:text-white">
								Ver cursos y precios
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="mb-12 max-w-3xl">
					<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Mi forma de preparar</h2>
					<p class="mt-4 text-lg leading-relaxed text-text-muted">La preparación combina explicación, práctica y seguimiento. No se trata de acumular material, sino de saber qué estudiar, cuándo repasarlo y cómo entrenar el examen.</p>
				</div>
				<div class="grid gap-5 md:grid-cols-3">
					{methodItems.map((item) => (
						<article class="rounded-2xl border border-primary/10 bg-bg-light/40 p-6">
							<h3 class="text-xl font-extrabold text-primary">{item.title}</h3>
							<p class="mt-4 leading-relaxed text-text-muted">{item.desc}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="px-4 py-20 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="mb-12 max-w-3xl">
					<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Elige tu camino de preparación</h2>
					<p class="mt-4 text-lg leading-relaxed text-text-muted">Cada oposición tiene una página específica para consultar estructura, enfoque y modalidades relacionadas.</p>
				</div>
				<div class="grid gap-5 md:grid-cols-3">
					{routes.map((route) => (
						<article class={`relative flex h-full flex-col rounded-2xl border bg-white p-6 shadow-[0_16px_42px_-34px_rgba(45,40,40,0.45)] ${route.highlight ? 'border-accent/80 ring-1 ring-accent/35 shadow-[0_24px_58px_-38px_rgba(254,172,124,0.95)]' : 'border-secondary/35'}`}>
							{route.highlight && (
								<span class="absolute right-5 top-5 rounded-full bg-accent px-3 py-1 text-xs font-bold uppercase tracking-widest text-primary">Recomendado</span>
							)}
							<h3 class="text-xl font-extrabold text-primary">{route.title}</h3>
							<p class="mt-4 grow leading-relaxed text-text-muted">{route.text}</p>
							<a href={route.href} class={`mt-6 inline-flex justify-center rounded-xl px-5 py-3 font-bold no-underline transition-colors ${route.highlight ? 'bg-accent text-primary hover:bg-primary hover:text-white' : 'border border-secondary text-secondary hover:bg-secondary hover:text-white'}`}>
								{route.cta}
							</a>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="mb-12 max-w-3xl">
					<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Lo que dicen los alumnos</h2>
					<p class="mt-4 text-lg leading-relaxed text-text-muted">Las reseñas ayudan a contrastar el método con experiencias reales de alumnos.</p>
				</div>
				<div class="mx-auto max-w-6xl">
					<TestimonialWidget variant="grid" />
				</div>
			</div>
		</section>

		<section class="px-4 py-20 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-5xl">
				<CTABanner
					title="¿Quieres que preparemos tu plaza?"
					subtitle="Hablamos sobre tu situación y vemos qué modalidad encaja mejor con tu punto de partida."
					ctaText="Contactar ahora"
					ctaHref="/contacto/"
				/>
			</div>
		</section>
	</main>
</BaseLayout>
