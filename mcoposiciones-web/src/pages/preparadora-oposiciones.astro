---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import TestimonialWidget from '../components/TestimonialWidget.astro';
import CTABanner from '../components/CTABanner.astro';
import PreparationRouteCard from '../components/PreparationRouteCard.astro';
import { Image } from 'astro:assets';
import mariaCarmenImage from '../assets/images/maria-carmen.jpg';
import { createPersonSchema } from '../lib/schema';

const schemaJson = JSON.stringify(createPersonSchema());

const trustItems = [
	'Preparación especializada en AGE C1 y Seguridad Social C1',
	'Grupos reducidos y atención directa durante el proceso',
	'Clases online en directo, grabaciones y material actualizado',
];

const methodItems = [
	{
		title: 'Explicar antes de memorizar',
		desc: 'Cada tema se trabaja con contexto, esquemas y ejemplos para que entiendas la lógica jurídica antes de pasar al test.',
		icon: 'book',
	},
	{
		title: 'Practicar con criterio de examen',
		desc: 'Los test, supuestos y repasos no se dejan para el final: se integran en el estudio para ganar seguridad y detectar errores a tiempo.',
		icon: 'clipboard',
	},
	{
		title: 'Ordenar el estudio semana a semana',
		desc: 'La planificación se adapta a tu disponibilidad real para avanzar con constancia, sin acumular material ni perder el foco.',
		icon: 'calendar',
	},
];

const routes = [
	{
		title: 'Administrativo del Estado',
		kicker: 'AGE C1',
		text: 'AGE C1 con temario legislativo, ofimática y entrenamiento de examen.',
		href: '/oposiciones-administrativo-estado/',
		cta: 'Ver AGE C1',
	},
	{
		title: 'Seguridad Social',
		kicker: 'Seguridad Social C1',
		text: 'Preparación C1 con temario específico y supuesto práctico desde el inicio.',
		href: '/oposiciones-seguridad-social/',
		cta: 'Ver Seguridad Social',
	},
	{
		title: 'AGE + Seguridad Social',
		kicker: 'Preparación conjunta',
		text: 'Preparación conjunta para aprovechar el temario común y ampliar opciones.',
		href: '/preparar-age-y-seguridad-social/',
		cta: 'Ver pack conjunto',
		highlight: true,
	},
];
---
<BaseLayout
	title="Mª Carmen — Preparadora Online AGE y Seguridad Social | MC Oposiciones"
	description="Conoce a Mª Carmen, preparadora online de oposiciones AGE C1 y Seguridad Social C1. Clases en directo, grupos reducidos y seguimiento cercano."
	canonicalUrl="https://mcoposiciones.com/preparadora-oposiciones/"
	schemaJson={schemaJson}
>
	<main class="overflow-x-hidden pt-24">
		<section class="px-4 py-16 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Preparadora de oposiciones', href: '' }]} />
				<div class="mt-12 grid gap-16 lg:grid-cols-[420px_1fr] lg:items-center">
					<div class="relative max-w-md">
						<div class="relative overflow-hidden rounded-2xl border border-primary/5 bg-white shadow-premium">
							<Image src={mariaCarmenImage} alt="Mª Carmen, preparadora de oposiciones AGE y Seguridad Social" width={600} height={600} loading="eager" fetchpriority="high" class="aspect-square h-full w-full object-cover transition-transform duration-700 hover:scale-105" />
						</div>
					</div>
					<div>
						<p class="text-sm font-extrabold uppercase tracking-[0.2em] text-secondary/90">Preparadora de oposiciones online</p>
						<h1 class="mt-4 text-4xl font-extrabold leading-tight text-primary md:text-6xl">Mª Carmen, preparadora de oposiciones AGE y Seguridad Social</h1>
						<p class="mt-6 max-w-3xl text-lg leading-relaxed text-text-muted/90 md:text-xl">
							Preparo opositores de Administrativo del Estado y Seguridad Social con una metodología cercana, exigente y centrada en el examen real. Mi trabajo es ayudarte a estudiar con estructura, entender el temario y mantener una estrategia sólida hasta la convocatoria.
						</p>
						<div class="mt-10 grid gap-4">
							{trustItems.map((item) => (
								<div class="flex items-center gap-4 rounded-xl border border-primary/5 bg-white px-5 py-4 text-sm font-bold text-primary shadow-sm transition-all duration-300 hover:shadow-premium hover:-translate-y-0.5">
									<span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-secondary/10 text-secondary">
										<svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" /></svg>
									</span>
									<span class="tracking-tight">{item}</span>
								</div>
							))}
						</div>
						<div class="mt-10 flex flex-col gap-4 sm:flex-row">
							<a href="/contacto/" class="inline-flex justify-center rounded-xl bg-secondary px-8 py-4 font-bold text-white no-underline shadow-button transition-all duration-300 hover:bg-primary hover:scale-[1.02] active:scale-[0.98]">
								Consultar preparación
							</a>
							<a href="/cursos-precios/" class="inline-flex justify-center rounded-xl border border-secondary/30 px-8 py-4 font-bold text-secondary no-underline transition-all duration-300 hover:bg-secondary/5 hover:border-secondary hover:scale-[1.02] active:scale-[0.98]">
								Ver cursos y precios
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="bg-white/50 px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="mb-14 max-w-3xl">
					<h2 class="text-3xl font-extrabold tracking-tight text-primary md:text-5xl">Mi forma de preparar</h2>
					<p class="mt-5 text-lg leading-relaxed text-text-muted/90">La preparación combina explicación clara, práctica guiada y seguimiento continuo. No se trata de acumular apuntes, sino de saber qué estudiar, cómo repasarlo y cuándo entrenar el examen.</p>
				</div>
				<div class="grid overflow-hidden rounded-2xl border border-primary/8 bg-white shadow-premium md:grid-cols-3">
					{methodItems.map((item) => (
						<article class="group relative border-b border-primary/8 p-7 transition-colors duration-300 last:border-b-0 hover:bg-bg-light/55 md:border-b-0 md:border-r md:last:border-r-0 lg:p-8">
							<div class="mb-7 flex h-13 w-13 items-center justify-center rounded-xl border border-secondary/15 bg-bg-light text-secondary transition-colors group-hover:border-secondary/25 group-hover:bg-secondary/10">
								{item.icon === 'book' && (
									<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M4 19.5V5.75A2.75 2.75 0 0 1 6.75 3H20v17H6.75A2.75 2.75 0 0 0 4 22.75" />
										<path d="M8 7h7" />
										<path d="M8 11h8" />
									</svg>
								)}
								{item.icon === 'clipboard' && (
									<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M9 4.5h6" />
										<path d="M9.5 3h5a1.5 1.5 0 0 1 1.5 1.5V6H8V4.5A1.5 1.5 0 0 1 9.5 3Z" />
										<path d="M7 5.5H6A2 2 0 0 0 4 7.5V19a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5a2 2 0 0 0-2-2h-1" />
										<path d="m8.5 13 2 2 5-5" />
									</svg>
								)}
								{item.icon === 'calendar' && (
									<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M7 3v3" />
										<path d="M17 3v3" />
										<path d="M4.5 9h15" />
										<rect x="4" y="5" width="16" height="16" rx="2.5" />
										<path d="M8 13h3" />
										<path d="M8 17h6" />
									</svg>
								)}
							</div>
							<h3 class="text-xl font-extrabold tracking-tight text-primary transition-colors group-hover:text-secondary">{item.title}</h3>
							<p class="mt-4 leading-relaxed text-text-muted/85">{item.desc}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="mb-16 max-w-3xl">
					<h2 class="text-3xl font-extrabold tracking-tight text-primary md:text-5xl">Elige tu camino</h2>
					<p class="mt-5 text-lg leading-relaxed text-text-muted/90">Cada oposición tiene una página específica para consultar estructura, enfoque y modalidades.</p>
				</div>
				<div class="grid gap-6 md:grid-cols-3">
					{routes.map((route) => (
						<PreparationRouteCard {...route} />
					))}
				</div>
			</div>
		</section>

		<section class="bg-white/50 px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="mb-16 max-w-3xl">
					<h2 class="text-3xl font-extrabold tracking-tight text-primary md:text-5xl">Lo que dicen los alumnos</h2>
					<p class="mt-5 text-lg leading-relaxed text-text-muted/90">Las reseñas ayudan a contrastar el método con experiencias reales.</p>
				</div>
				<div class="mx-auto max-w-6xl">
					<TestimonialWidget variant="grid" />
				</div>
				<div class="mx-auto mt-16 max-w-5xl">
					<CTABanner
						title="¿Quieres que preparemos tu plaza?"
						subtitle="Hablamos sobre tu situación y vemos qué modalidad encaja mejor con tu punto de partida."
						ctaText="Contactar ahora"
						ctaHref="/contacto/"
					/>
				</div>
			</div>
		</section>
	</main>
</BaseLayout>
