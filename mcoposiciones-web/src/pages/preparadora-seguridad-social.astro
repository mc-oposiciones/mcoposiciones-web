---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import TestimonialWidget from '../components/TestimonialWidget.astro';
import { createPreparadoraLandingSchema, withFAQSchema } from '../lib/schema';

const canonicalUrl = 'https://mcoposiciones.com/preparadora-seguridad-social/';

const faqItems = [
	{
		question: '¿Qué incluye la preparación de Seguridad Social?',
		answer: 'Incluye clases online en directo, grabaciones, temario común y específico, test, supuestos prácticos y planificación para llegar al examen con criterio.',
	},
	{
		question: '¿La Seguridad Social tiene prueba de ofimática?',
		answer: 'No. La oposición de Administrativo de la Seguridad Social no tiene la misma prueba de ofimática que AGE. El peso está en el temario y el supuesto práctico.',
	},
	{
		question: '¿El supuesto práctico se prepara desde el principio?',
		answer: 'Sí. En esta oposición el supuesto práctico es clave, por eso se trabaja desde los primeros meses y no se deja para el final.',
	},
	{
		question: '¿Puedo aprovechar lo estudiado para AGE?',
		answer: 'Sí. Gran parte del temario es común. Si vienes de AGE, puedes centrarte en los temas específicos de Seguridad Social y el supuesto práctico.',
	},
];

const schemaJson = JSON.stringify(withFAQSchema(createPreparadoraLandingSchema({
	url: canonicalUrl,
	name: 'Preparadora oposiciones Seguridad Social C1 online',
	description: 'Preparación online con Mª Carmen para las oposiciones de Administrativo de la Seguridad Social C1. Temario específico, supuestos prácticos, clases en directo y seguimiento cercano.',
	courseName: 'Preparación oposiciones Administrativo de la Seguridad Social C1',
}), faqItems));
---

<BaseLayout
	title="Preparadora Seguridad Social Online | Administrativo C1 | MC Oposiciones"
	description="Prepara las oposiciones de Administrativo de la Seguridad Social con Mª Carmen. Clases en directo, temario actualizado 2026, supuesto práctico y grupos reducidos."
	canonicalUrl={canonicalUrl}
	schemaJson={schemaJson}
>
	<main class="overflow-x-hidden pt-24">
		<section class="px-4 py-16 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Preparadora Seguridad Social', href: '' }]} />
				<div class="mt-12 grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
					<header>
						<p class="text-sm font-extrabold uppercase tracking-widest text-secondary">Preparación online Seguridad Social C1</p>
						<h1 class="mt-4 text-4xl font-extrabold leading-tight text-primary md:text-6xl">
							Preparadora de oposiciones de Seguridad Social
						</h1>
						<p class="mt-6 max-w-3xl text-lg leading-relaxed text-text-muted md:text-xl">
							Prepara Administrativo de la Seguridad Social C1 con clases online en directo, temario común y específico, supuestos prácticos y una planificación clara para avanzar con seguridad.
						</p>
						<div class="mt-10 flex flex-col gap-4 sm:flex-row">
							<a href="/contacto/" class="rounded-xl bg-secondary px-8 py-4 text-center font-bold text-white no-underline transition-colors hover:bg-primary">
								Pedir información SS
							</a>
							<a href="/oposiciones-seguridad-social/" class="rounded-xl border border-secondary px-8 py-4 text-center font-bold text-secondary no-underline transition-colors hover:bg-secondary hover:text-white">
								Ver detalles de la oposición
							</a>
						</div>
					</header>
					<aside class="rounded-2xl border border-primary/10 bg-white p-8">
						<h2 class="text-2xl font-extrabold text-primary">¿Por qué preparar Seguridad Social?</h2>
						<ul class="mt-6 space-y-4">
							<li class="flex gap-3"><span class="font-black text-secondary">01</span><span>Es una oposición C1 con temario muy conectado con AGE.</span></li>
							<li class="flex gap-3"><span class="font-black text-secondary">02</span><span>No tiene prueba de ofimática como Administrativo del Estado.</span></li>
							<li class="flex gap-3"><span class="font-black text-secondary">03</span><span>El supuesto práctico se puede entrenar con método desde el inicio.</span></li>
							<li class="flex gap-3"><span class="font-black text-secondary">04</span><span>Permite aprovechar parte del estudio si ya vienes de AGE.</span></li>
						</ul>
					</aside>
				</div>
			</div>
		</section>

		<section class="bg-white/50 px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="mb-14 max-w-3xl">
					<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Preparación específica para Seguridad Social</h2>
					<p class="mt-6 text-lg leading-relaxed text-text-muted">
						La oposición exige dominar el temario común, la normativa propia de Seguridad Social y la aplicación práctica. Por eso la preparación combina teoría, test y supuestos desde una planificación ordenada.
					</p>
				</div>
				<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
					{[
						{ title: 'Temario específico', text: 'Trabajo detallado de los temas propios de Seguridad Social.' },
						{ title: 'Supuestos prácticos', text: 'Entrenamiento constante para aplicar la ley en casos de examen.' },
						{ title: 'Test por bloques', text: 'Práctica continua para detectar errores y consolidar conceptos.' },
						{ title: 'Plan de estudio', text: 'Organización semanal adaptada al tiempo real disponible.' },
					].map((item) => (
						<article class="rounded-2xl border border-primary/10 bg-bg-light/40 p-6">
							<h3 class="text-xl font-bold text-primary">{item.title}</h3>
							<p class="mt-3 text-sm leading-relaxed text-text-muted">{item.text}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-2 lg:items-start">
				<div>
					<h2 class="text-3xl font-extrabold text-primary md:text-4xl">El supuesto práctico no se improvisa</h2>
					<p class="mt-6 text-lg leading-relaxed text-text-muted">
						En Seguridad Social no basta con haber leído el temario. Hay que saber aplicar conceptos a situaciones concretas y reconocer qué pregunta realmente plantea el supuesto.
					</p>
					<p class="mt-4 text-lg leading-relaxed text-text-muted">
						Por eso el método trabaja supuestos desde el principio, junto con test y explicaciones orientadas al examen.
					</p>
				</div>
				<div class="rounded-2xl border border-accent/30 bg-accent/10 p-8">
					<h3 class="text-2xl font-extrabold text-primary">Si vienes de AGE, puedes aprovechar mucho</h3>
					<p class="mt-4 leading-relaxed text-text-main">
						El temario común permite plantear una preparación conjunta o una adaptación específica hacia Seguridad Social.
					</p>
					<a href="/preparar-age-y-seguridad-social/" class="mt-6 inline-flex rounded-xl bg-accent px-5 py-3 font-bold text-primary no-underline transition-colors hover:bg-primary hover:text-white">Ver preparación conjunta</a>
				</div>
			</div>
		</section>

		<section class="bg-white/50 px-4 py-20 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="grid gap-8 rounded-2xl border border-primary/10 bg-bg-light/40 p-8 md:grid-cols-[1fr_auto] md:items-center">
					<div>
						<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Conoce bien la oposición antes de empezar</h2>
						<p class="mt-4 leading-relaxed text-text-muted">
							Si todavía estás comparando opciones, puedes revisar cómo es el examen, qué peso tiene el supuesto práctico y qué partes del temario conviene priorizar desde el principio.
						</p>
					</div>
					<a href="/oposiciones-seguridad-social/" class="inline-flex justify-center rounded-xl border border-secondary px-6 py-3 font-bold text-secondary no-underline transition-colors hover:bg-secondary hover:text-white">
						Ver Seguridad Social C1
					</a>
				</div>

				<div class="mx-auto mt-12 max-w-6xl border-t border-primary/10 pt-12">
					<div class="mb-8 text-center">
						<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Opiniones de alumnos</h2>
					</div>
					<TestimonialWidget variant="grid" />
				</div>
			</div>
		</section>

		<section class="px-4 py-20 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-4xl">
				<h2 class="mb-10 text-center text-3xl font-extrabold text-primary md:text-4xl">Preguntas frecuentes sobre Seguridad Social</h2>
				<FAQAccordion items={faqItems} />
			</div>

			<div class="mx-auto mt-16 max-w-5xl">
				<CTABanner
					title="¿Quieres preparar Seguridad Social con método?"
					subtitle="Escríbeme y vemos si el grupo encaja con tu nivel, disponibilidad y objetivo de examen."
					ctaText="Pedir información"
					ctaHref="/contacto/"
					variant="primary"
				/>
			</div>
		</section>
	</main>
</BaseLayout>
