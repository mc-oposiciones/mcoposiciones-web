---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTABanner from '../components/CTABanner.astro';
import InfoStepsCard from '../components/InfoStepsCard.astro';
import { createDualCoursePageSchema, withFAQSchema } from '../lib/schema';

const examFacts = [
	'Base común aprovechable',
	'AGE incluye ofimática',
	'Seguridad Social incluye supuesto específico',
	'Plan semanal combinado',
];

const preparationBlocks = [
	{
		title: 'Base común una sola vez',
		text: 'Constitución, organización administrativa, procedimiento, función pública y materias generales se trabajan con una planificación compartida.',
	},
	{
		title: 'Bloque propio de AGE',
		text: 'La parte específica de AGE, la ofimática y el enfoque del ejercicio de Administrativo del Estado se integran desde el principio para no dejarlos al final.',
	},
	{
		title: 'Bloque propio de Seguridad Social',
		text: 'La parte específica y el supuesto práctico se preparan con ejemplos, casos y corrección guiada para consolidar criterio.',
	},
];

const studyDistribution = [
	{
		title: 'Base común',
		text: 'Se estudia una sola vez para aprovechar cada hora y construir una base administrativa sólida.',
	},
	{
		title: 'Bloque AGE',
		text: 'Se añade parte específica, ofimática y entrenamiento específico del ejercicio de Administrativo del Estado.',
	},
	{
		title: 'Bloque Seguridad Social',
		text: 'Se incorpora temario propio y supuesto práctico con casos, ejemplos y corrección guiada.',
	},
];

const includedItems = [
	'Temario común organizado por bloques',
	'Clases específicas de Seguridad Social',
	'Parte específica y ofimática completa para AGE',
	'Test diferenciados por oposición',
	'Supuestos prácticos y simulacros',
	'Planificación semanal conjunta',
];

const packPrices = [
	{ label: 'Modalidad mensual', price: '150€', detail: '/mes', saving: 'Ahorro de 50€/mes frente a contratar ambas por separado.' },
	{ label: 'Curso completo', price: '650€', detail: 'pago único', saving: 'Ahorro de 300€ frente a dos cursos completos individuales.' },
];

const comparisonRows = [
	{ label: 'Preparación AGE', value: 'Temario general, parte específica, supuesto y ofimática' },
	{ label: 'Preparación Seguridad Social', value: 'Temario general, específico y supuesto propio' },
	{ label: 'Pack conjunto', value: 'Aprovecha lo común y separa lo específico con orden', highlight: true },
];

const faqItems = [
	{ question: '¿Se puede llevar bien el ritmo de preparar las dos oposiciones a la vez?', answer: 'Sí, siempre que exista una planificación realista. El temario común se estudia una sola vez y después se separan los bloques propios de AGE y Seguridad Social.' },
	{ question: '¿Cuántas horas semanales necesito?', answer: 'Lo importante es contar con una disponibilidad estable y una planificación realista. El pack se organiza para aprovechar el temario común y separar con claridad los bloques propios de AGE y Seguridad Social.' },
	{ question: '¿Qué pasa si más adelante quiero centrarme solo en una?', answer: 'Se puede reajustar el plan. La preparación conjunta parte de una base común, así que el trabajo inicial no se pierde aunque después decidas priorizar AGE o Seguridad Social.' },
	{ question: '¿Es mejor preparar ambas o elegir una sola?', answer: 'Preparar ambas puede ampliar opciones, aprovechar mejor el temario común y darte más oportunidades para conseguir una plaza.' },
];

const schemaJson = JSON.stringify(withFAQSchema(createDualCoursePageSchema({
	url: 'https://mcoposiciones.com/preparar-age-y-seguridad-social/',
	pageName: 'Preparar AGE y Seguridad Social a la vez',
	pageDescription: 'Preparación conjunta de Administrativo del Estado AGE C1 y Administrativo de la Seguridad Social C1 aprovechando el temario común.',
}), faqItems));
---

<BaseLayout
	title="Preparar AGE y Seguridad Social a la vez | MC Oposiciones"
	description="Prepara AGE y Seguridad Social a la vez aprovechando el temario común. Pack conjunto con Mª Carmen: clases en directo, grupos reducidos y planificación unificada."
	canonicalUrl="https://mcoposiciones.com/preparar-age-y-seguridad-social/"
	schemaJson={schemaJson}
>
	<main class="overflow-x-hidden pt-24">
		<section class="px-4 py-16 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Pack AGE + Seguridad Social', href: '' }]} />
				<header class="mt-12 max-w-4xl">
					<p class="text-sm font-bold uppercase tracking-widest text-secondary">Preparación conjunta C1</p>
					<h1 class="mt-4 text-4xl font-extrabold leading-tight text-primary md:text-6xl">
						Prepara AGE y Seguridad Social <span class="text-secondary">a la vez</span>
					</h1>
					<p class="mt-6 text-lg leading-relaxed text-text-muted md:text-xl">
						Una opción pensada para opositores que quieren ampliar oportunidades sin estudiar dos preparaciones desconectadas.
					</p>
					<div class="mt-8 flex flex-col gap-3 sm:flex-row">
						<a href="#precios-pack" class="inline-flex justify-center rounded-xl bg-accent px-6 py-3 font-bold text-primary no-underline transition-colors hover:bg-primary hover:text-white">
							Ver precios del pack
						</a>
						<a href="/contacto/" class="inline-flex justify-center rounded-xl border border-secondary px-6 py-3 font-bold text-secondary no-underline transition-colors hover:bg-secondary hover:text-white">
							Consultar si encaja conmigo
						</a>
					</div>
				</header>
			</div>
		</section>

		<section class="bg-white/50 px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="grid gap-12 lg:grid-cols-2 lg:items-center">
					<div>
						<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Por qué tiene sentido preparar ambas</h2>
						<p class="mt-6 text-lg leading-relaxed text-text-muted">
							AGE y Seguridad Social comparten una base administrativa importante. La clave no es duplicar horas, sino estudiar lo común con orden y reservar espacios claros para lo específico de cada oposición.
						</p>
						<div class="mt-10 grid gap-4 sm:grid-cols-2">
							{examFacts.map((item, index) => (
								<div class="flex items-center gap-3 rounded-xl border border-primary/5 bg-white p-4 font-bold text-primary shadow-sm transition-all duration-300 hover:shadow-premium">
									<span class={`h-2.5 w-2.5 shrink-0 rounded-full ${index === 0 ? 'bg-accent' : 'bg-secondary'}`}></span>
									<span class="text-sm tracking-tight">{item}</span>
								</div>
							))}
						</div>
					</div>
					<InfoStepsCard title="Cómo se reparte el estudio" eyebrow="Plan combinado" items={studyDistribution} accent="orange" />
				</div>
			</div>
		</section>

		<section class="px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="mb-12 max-w-3xl">
					<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Cómo se organiza la preparación conjunta</h2>
					<p class="mt-4 text-text-muted">
						La página explica el enfoque del pack y muestra el ahorro principal. La tabla completa de modalidades se mantiene centralizada en precios para que sea fácil comparar.
					</p>
				</div>
				<div class="grid gap-5 md:grid-cols-3">
					{preparationBlocks.map((block) => (
						<article class="rounded-2xl border border-primary/10 bg-white p-6">
							<h3 class="text-xl font-extrabold text-primary">{block.title}</h3>
							<p class="mt-4 leading-relaxed text-text-muted">{block.text}</p>
						</article>
					))}
				</div>

				<div id="precios-pack" class="mt-10 scroll-mt-28 rounded-2xl border border-accent/30 bg-accent/10 p-6 md:flex md:items-end md:justify-between md:gap-8">
					<div class="max-w-3xl">
						<p class="text-xs font-bold uppercase tracking-[0.18em] text-accent">Opción recomendada si tienes disponibilidad</p>
						<h3 class="mt-2 text-2xl font-extrabold text-primary">Un plan para ampliar opciones sin estudiar a ciegas</h3>
						<p class="mt-3 text-text-muted">
							El pack conjunto encaja especialmente bien si puedes sostener una dedicación semanal estable y quieres aprovechar el temario común. Además, es más económico que contratar las dos preparaciones por separado.
						</p>
						<div class="mt-6 grid gap-5 sm:grid-cols-2">
							{packPrices.map((item) => (
								<div class="border-l-2 border-accent/60 pl-4">
									<p class="m-0 text-xs font-extrabold uppercase tracking-widest text-accent">{item.label}</p>
									<div class="mt-1 flex items-baseline gap-1">
										<p class="m-0 text-2xl font-black text-primary">{item.price}</p>
										<p class="m-0 text-sm font-bold text-text-muted/65">{item.detail}</p>
									</div>
									<p class="m-0 mt-2 text-xs font-semibold leading-relaxed text-text-muted">{item.saving}</p>
								</div>
							))}
						</div>
					</div>
					<a href="/cursos-precios/#pack-age-ss" class="mt-6 inline-flex rounded-xl bg-accent px-6 py-3 font-bold text-primary no-underline transition-colors hover:bg-primary hover:text-white md:mt-0 md:shrink-0">
						Ver tabla completa
					</a>
				</div>
			</div>
		</section>

		<section class="bg-white/50 px-4 py-24 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-7xl">
				<div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
					<div>
						<h2 class="text-3xl font-extrabold text-primary md:text-4xl">Qué incluye el pack</h2>
						<p class="mt-6 text-lg leading-relaxed text-text-muted">
							No se trata de sumar dos cursos sin más. La preparación conjunta necesita separar prioridades y trabajar cada oposición con su propia lógica.
						</p>
					</div>
					<div class="grid gap-4 sm:grid-cols-2">
						{includedItems.map((item) => (
							<div class="flex items-center gap-3 rounded-xl border border-primary/5 bg-white p-4 font-bold text-primary shadow-sm transition-all duration-300 hover:shadow-premium">
								<span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-secondary/10 text-sm font-black text-secondary">✓</span>
								<span class="text-sm tracking-tight">{item}</span>
							</div>
						))}
					</div>
				</div>

				<div class="mt-12 overflow-hidden rounded-2xl border border-primary/10 bg-white shadow-premium">
					{comparisonRows.map((row) => (
						<div class={`grid min-h-[64px] items-center gap-2 border-b border-primary/5 px-6 py-3.5 last:border-b-0 sm:grid-cols-[0.8fr_1.2fr] sm:gap-8 ${row.highlight ? 'bg-accent/12 shadow-[inset_5px_0_0_rgba(204,121,57,0.95)]' : ''}`}>
							<div class="flex min-h-0 items-center justify-between gap-4 sm:justify-start">
								<p class={`m-0 font-extrabold leading-none ${row.highlight ? 'text-accent' : 'text-secondary'}`}>{row.label}</p>
								{row.highlight && (
									<span class="shrink-0 rounded-full border border-accent/35 bg-accent/18 px-3 py-1 text-[10px] font-extrabold uppercase tracking-widest text-accent">Recomendado</span>
								)}
							</div>
							<p class={`m-0 flex min-h-0 items-center leading-snug ${row.highlight ? 'font-semibold text-primary' : 'text-text-muted'}`}>{row.value}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="px-4 py-20 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-4xl">
				<h2 class="mb-10 text-center text-3xl font-extrabold text-primary md:text-4xl">Dudas sobre preparar AGE y Seguridad Social</h2>
				<FAQAccordion items={faqItems} />
			</div>

			<div class="mx-auto mt-16 max-w-5xl">
				<CTABanner
					title="¿Quieres saber si te conviene preparar ambas?"
					subtitle="Cuéntame tu disponibilidad, tu base y tu objetivo. Te diré con claridad si el pack conjunto tiene sentido para ti."
					ctaText="Pedir orientación"
					ctaHref="/contacto/"
					variant="primary"
				/>
			</div>
		</section>
	</main>
</BaseLayout>
